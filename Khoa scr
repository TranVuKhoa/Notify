local function applyGodMode3(char)
    if not char then return end
    local hum = char:WaitForChild("Humanoid", 3)
    if not hum then return end
    
    if godMode3Conn then godMode3Conn:Disconnect(); godMode3Conn = nil end
    
    hum:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
    hum.BreakJointsOnDeath = false
    
    local ff = char:FindFirstChildOfClass("ForceField") or Instance.new("ForceField", char)
    ff.Visible = false

    hum.MaxHealth = math.huge
    hum.Health = math.huge

    godMode3Conn = runService.Heartbeat:Connect(function()
        if godMode3Active and hum and hum.Parent then
            if hum.Health < hum.MaxHealth then
                hum.Health = hum.MaxHealth
            end
            if hum:GetState() == Enum.HumanoidStateType.Dead then
                hum:ChangeState(Enum.HumanoidStateType.GettingUp)
            end
            local creator = hum:FindFirstChild("creator")
            if creator then creator:Destroy() end
        end
    end)
    SendNotify("God Mode 3", "Cường hóa khiên ForceField & Chống tử vong tuyệt đối!", 3)
end

