    MainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    MainFrame.Size = UDim2.new(0, 280, 0, 80)
    MainFrame.Position = UDim2.new(1, 50, 1, -100)
    
    local UICorner = Instance.new("UICorner", MainFrame)
    UICorner.CornerRadius = UDim.new(0, 5)

    local UIStroke = Instance.new("UIStroke", MainFrame)
    UIStroke.Color = Color3.fromRGB(255, 255, 0)
    UIStroke.Thickness = 2

    local TitleLabel = Instance.new("TextLabel", MainFrame)
    TitleLabel.Text = title; TitleLabel.TextColor3 = Color3.fromRGB(255, 255, 0); TitleLabel.Font = Enum.Font.GothamBold; TitleLabel.TextSize = 16
    TitleLabel.Position = UDim2.new(0, 10, 0, 10); TitleLabel.Size = UDim2.new(0, 260, 0, 20); TitleLabel.BackgroundTransparency = 1; TitleLabel.TextXAlignment = "Left"

    local ContentLabel = Instance.new("TextLabel", MainFrame)
    ContentLabel.Text = text; ContentLabel.TextColor3 = Color3.new(1, 1, 1); ContentLabel.Font = Enum.Font.Gotham; ContentLabel.TextSize = 14
    ContentLabel.Position = UDim2.new(0, 10, 0, 35); ContentLabel.Size = UDim2.new(0, 260, 0, 40); ContentLabel.BackgroundTransparency = 1; ContentLabel.TextXAlignment = "Left"; ContentLabel.TextWrapped = true

    MainFrame:TweenPosition(UDim2.new(1, -300, 1, -100), "Out", "Quad", 0.5, true)
    task.delay(duration or 5, function()
        if ScreenGui then
            pcall(function()
                MainFrame:TweenPosition(UDim2.new(1, 50, 1, -100), "In", "Quad", 0.5, true, function() ScreenGui:Destroy() end)
            end)
        end
    end)
end

