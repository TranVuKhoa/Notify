-- [[ KHU VỰC NÚT BẤM STYLE CLASSIC ]]
local function createClassicBtn(parent, txt, isGrid, callback)
    local btn = Instance.new("TextButton", parent)
    if not isGrid then btn.Size = UDim2.new(0.9, 0, 0, 30) end
    btn.BackgroundTransparency = 1; btn.Text = ""
    local box = Instance.new("Frame", btn)
    box.Size = UDim2.new(0, 22, 0, 26); box.Position = UDim2.new(0, 10, 0.5, -13); box.BackgroundColor3 = Color3.fromRGB(22, 22, 22); box.BorderSizePixel = 0
    local lbl = Instance.new("TextLabel", btn)
    lbl.Text = txt; lbl.Size = UDim2.new(1, -40, 1, 0); lbl.Position = UDim2.new(0, 42, 0, 0); lbl.BackgroundTransparency = 1; lbl.TextColor3 = Color3.new(0.9, 0.9, 0.9); lbl.Font = Enum.Font.Antique; lbl.TextSize = 19; lbl.TextXAlignment = "Left"
    
    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        box.BackgroundColor3 = active and Color3.fromRGB(150, 150, 150) or Color3.fromRGB(22, 22, 22)
        callback(active)
    end)
end

