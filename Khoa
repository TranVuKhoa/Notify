-- [[ LOGIC CHẠM TƯỜNG & MULTI-TOUCH ]]
local activeTouches = {}
uis.InputBegan:Connect(function(input, gpe)
    if tapWallActive and not gpe and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1) then
        local pos = input.Position
        local ray = cam:ScreenPointToRay(pos.X, pos.Y)
        local params = RaycastParams.new()
        local filter = {}
        if lp.Character then table.insert(filter, lp.Character) end
        if ghostModel then table.insert(filter, ghostModel) end
        params.FilterDescendantsInstances = filter
        params.FilterType = Enum.RaycastFilterType.Exclude
        
        local result = workspace:Raycast(ray.Origin, ray.Direction * 1000, params)
        if result and result.Instance then
            local root = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if root then
                local camDir = ray.Direction.Unit
                local destPos = result.Position + (camDir * 8) 
                local safeRayOrigin = Vector3.new(destPos.X, destPos.Y + 10, destPos.Z)
                local safeRayDirection = Vector3.new(0, -30, 0)
                local safeResult = workspace:Raycast(safeRayOrigin, safeRayDirection, params)
                if safeResult and safeResult.Instance then
                    root.CFrame = CFrame.new(safeResult.Position + Vector3.new(0, 3.5, 0))
                    SendNotify("Tap Wall", "Đã xuyên qua thành công!", 1.5)
                else
                    root.CFrame = CFrame.new(destPos.X, root.Position.Y, destPos.Z)
                    SendNotify("Tap Wall", "Giữ nguyên độ cao!", 2)
                end
            end
        end
    end

    if input.UserInputType == Enum.UserInputType.Touch then
        activeTouches[input] = os.clock()
        task.delay(0.05, function()
            local count, minTime, maxTime = 0, math.huge, 0
            for _, timeStart in pairs(activeTouches) do count = count + 1; if timeStart < minTime then minTime = timeStart end; if timeStart > maxTime then maxTime = timeStart end end
            if (maxTime - minTime) <= 0.25 then
                if count == 3 then ToggleMenu(); activeTouches = {} elseif count == 4 then OpenBtn.Visible = not OpenBtn.Visible; SendNotify("Hệ Thống", OpenBtn.Visible and "Hiện Icon Mở Nhanh" or "Ẩn Icon Mở Nhanh", 2); activeTouches = {} end
            end
        end)
    end
end)
uis.InputEnded:Connect(function(input, gpe) if input.UserInputType == Enum.UserInputType.Touch then activeTouches[input] = nil end end)

