local activeTouches = {}
uis.InputBegan:Connect(function(input, gpe)
    if tapWallActive and not gpe and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1) then
        local pos = input.Position; local ray = cam:ScreenPointToRay(pos.X, pos.Y); local params = RaycastParams.new(); params.FilterDescendantsInstances = {lp.Character, ghostModel}; params.FilterType = Enum.RaycastFilterType.Exclude
        local result = workspace:Raycast(ray.Origin, ray.Direction * 1000, params)
        if result and result.Instance then local root = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart"); if root then local destPos = result.Position + (ray.Direction.Unit * 8); local safeResult = workspace:Raycast(destPos + Vector3.new(0,10,0), Vector3.new(0,-30,0), params); if safeResult then root.CFrame = CFrame.new(safeResult.Position + Vector3.new(0, 3.5, 0)) else root.CFrame = CFrame.new(destPos.X, root.Position.Y, destPos.Z) end; SendNotify("Tap Wall", "Xuyên tường thành công!", 1.5) end end
    end
    if input.UserInputType == Enum.UserInputType.Touch then activeTouches[input] = os.clock(); task.delay(0.05, function() local count, minT, maxT = 0, math.huge, 0; for _, t in pairs(activeTouches) do count = count + 1; minT = math.min(minT, t); maxT = math.max(maxT, t) end; if (maxT - minT) <= 0.25 then if count == 3 then ToggleMenu(); activeTouches = {} elseif count == 4 then OpenBtn.Visible = not OpenBtn.Visible; activeTouches = {} end end end) end
end)
uis.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.Touch then activeTouches[input] = nil end end)

-- ESP CACHE
local function getESP(p) if not espCache[p] then local data = {}; data.Box = Instance.new("Frame", ESPLayer); data.Box.BackgroundTransparency = 1; data.Box.Visible = false; local st = Instance.new("UIStroke", data.Box); st.Color = IOS_BLUE; st.Thickness = 1.5; data.Line = Instance.new("Frame", ESPLayer); data.Line.BackgroundColor3 = IOS_BLUE; data.Line.BorderSizePixel = 0; data.Line.AnchorPoint = Vector2.new(0.5, 0.5); data.Line.Visible = false; espCache[p] = data end return espCache[p] end

-- MAIN LOOP
local lastTick, fCount = os.clock(), 0
SendNotify("Vũ Khoa V31", "Hệ thống bảo vệ (Anti-Stun, FPS, Anti-AFK) đã chạy ngầm!", 4)

runService.RenderStepped:Connect(function(dt)
    if fpsActive then fCount = fCount + 1; local cur = os.clock(); if cur - lastTick >= 1 then FpsLabel.Text = "FPS: " .. fCount; fCount = 0; lastTick = cur end end
    local char = lp.Character; if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local root = char.HumanoidRootPart
    
    -- XỬ LÝ ANTI STUN MẶC ĐỊNH
    local hum = char:FindFirstChild("Humanoid")
    if hum then
        if hum.WalkSpeed < 16 then hum.WalkSpeed = 16 end 
        if hum.JumpPower < 50 then hum.JumpPower = 50 end
        hum.Sit = false; hum.PlatformStand = false
        local st = hum:GetState(); if st == Enum.HumanoidStateType.Ragdoll or st == Enum.HumanoidStateType.FallingDown or st == Enum.HumanoidStateType.Physics then hum:ChangeState(Enum.HumanoidStateType.GettingUp) end
    end
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("BasePart") and v.Anchored and v.Name == "HumanoidRootPart" then v.Anchored = false end
        if v:IsA("Weld") or v:IsA("WeldConstraint") then if (v.Part0 and not v.Part0:IsDescendantOf(char)) or (v.Part1 and not v.Part1:IsDescendantOf(char)) then v:Destroy() end end
    end

    -- FLY & MOVE
    if localMoveDir.Magnitude > 0 then
        local bv = root:FindFirstChild("VuKhoa_Fly") or Instance.new("BodyVelocity"); bv.Name = "VuKhoa_Fly"; bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        local mv = (root.CFrame.LookVector * -localMoveDir.Z) + (root.CFrame.RightVector * localMoveDir.X) + (Vector3.new(0,1,0) * localMoveDir.Y)
        bv.Velocity = mv.Unit * (currentSpeed * 50); bv.Parent = root
        if hum then hum:ChangeState(Enum.HumanoidStateType.Freefall) end
        for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end
    else
        local bv = root:FindFirstChild("VuKhoa_Fly"); if bv then bv:Destroy() if not ghostActive then for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = true end end end end
    end
    
    -- Lưu ý: Bỏ ghostActive ra khỏi logic ghim vị trí để Hồn có thể tự do đi lại!
    if ghimActive and lockedPos then root.CFrame = lockedPos; root.Velocity = Vector3.zero end
    if spinBotActive then root.CFrame = root.CFrame * CFrame.Angles(0, math.rad(50), 0) end

    -- ESP PROCESS
    local pCount = 0; local bC = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y)
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character.Humanoid.Health > 0 then
            pCount = pCount + 1; local eChar = p.Character; local eRoot = eChar.HumanoidRootPart
            if xrayActive then local h = eChar:FindFirstChild("TrVuKhoaa_ESP") or Instance.new("Highlight", eChar); h.FillColor = IOS_BLUE; h.Name = "TrVuKhoaa_ESP" else local h = eChar:FindFirstChild("TrVuKhoaa_ESP"); if h then h:Destroy() end end
            local espData = getESP(p); local hP, hV = cam:WorldToViewportPoint(eRoot.Position + Vector3.new(0, 3.5, 0)); local fP, fV = cam:WorldToViewportPoint(eRoot.Position - Vector3.new(0, 3.5, 0))
            if hV or fV then
                if espBoxActive then local h = math.abs(hP.Y - fP.Y); local w = h * 0.6; espData.Box.Size = UDim2.new(0, w, 0, h); espData.Box.Position = UDim2.new(0, hP.X - w/2, 0, hP.Y); espData.Box.Visible = true else espData.Box.Visible = false end
                if espLineActive then local pP = Vector2.new(fP.X, fP.Y); local d = (bC - pP).Magnitude; espData.Line.Size = UDim2.new(0, d, 0, 1.5); espData.Line.Position = UDim2.new(0, (bC.X + pP.X)/2, 0, (bC.Y + pP.Y)/2); espData.Line.Rotation = math.deg(math.atan2(pP.Y - bC.Y, pP.X - bC.X)); espData.Line.Visible = true else espData.Line.Visible = false end
            else espData.Box.Visible = false; espData.Line.Visible = false end
        else if espCache[p] then espCache[p].Box.Visible = false; espCache[p].Line.Visible = false end end
    end
    if espCountActive then CountLabel.Text = "Địch: " .. pCount end
end)
