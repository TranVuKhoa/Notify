--- [Chú thích: Tắt Bypass Teleport (Tính toán lướt theo nhịp để tránh bị giật lại)]
function TurnOffBypassTeleport()
    local char = lp.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") or not ghostModel then
        bypassTeleportActive = false
        if ghostModel then ghostModel:Destroy(); ghostModel = nil end
        BypassBtnFrame:FindFirstChildOfClass("TextButton").Text = "🛸"
        StopGhostAnimation()
        RestoreCharGhost()
        return
    end
    
    local hrp = char.HumanoidRootPart
    local endCFrame = ghostModel.HumanoidRootPart.CFrame
    local distance = (btStartCFrame.Position - endCFrame.Position).Magnitude
    
    ghostModel:Destroy()
    ghostModel = nil
    local hum = char:FindFirstChild("Humanoid")
    if hum then cam.CameraSubject = hum end
    
    local maxStep = 100
    local steps = math.ceil(distance / maxStep)
    
    BypassBtnFrame:FindFirstChildOfClass("TextButton").Text = "🛸"
    StopGhostAnimation()
    RestoreCharGhost()
    SendNotify("Bypass Teleport", L("Đang bay... ", "Teleporting... ") .. math.floor(distance) .. "m (" .. steps .. L(" nhịp)", " steps)"), 2.5)
    
    task.spawn(function()
        if steps > 1 then
            for i = 1, steps do
                hrp.CFrame = btStartCFrame:Lerp(endCFrame, i / steps)
                task.wait(0.15)
            end
        else
            hrp.CFrame = endCFrame
        end
        hrp.Anchored = false
        bypassTeleportActive = false
        SendNotify("Bypass Teleport", L("Đã đến đích an toàn!", "Arrived safely!"), 2)
    end)
end

