-- [[ TẠO NÚT TÍNH NĂNG ]]
local function createBtn(txt, callback)
    local btn = Instance.new("TextButton", Content)
    btn.Size = UDim2.new(0.92, 0, 0, 38); btn.BackgroundTransparency = 1; btn.Text = ""
    
    local bg = Instance.new("Frame", btn)
    bg.Size = UDim2.new(1, 0, 1, 0); bg.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 6)
    
    local box = Instance.new("Frame", btn)
    box.Size = UDim2.new(0, 16, 0, 16); box.Position = UDim2.new(0, 12, 0.5, -8); box.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 4)
    
    local lbl = Instance.new("TextLabel", btn)
    lbl.Text = txt; lbl.Size = UDim2.new(1, -40, 1, 0); lbl.Position = UDim2.new(0, 40, 0, 0); lbl.BackgroundTransparency = 1; lbl.TextColor3 = Color3.new(0.8, 0.8, 0.8); lbl.Font = "Gotham"; lbl.TextSize = 13; lbl.TextXAlignment = "Left"

    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        box.BackgroundColor3 = active and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(40, 40, 40)
        lbl.TextColor3 = active and Color3.new(1, 1, 1) or Color3.new(0.8, 0.8, 0.8)
        callback(active)
        CreateNotify("VKhoa Sync", txt.." : "..(active and "BẬT" or "TẮT"), 2)
    end)
end

-- Tính năng
local ghimActive, xrayActive, ghostActive, airWalkActive = false, false, false, false
local lockedPos, airWalkPart, ghostModel = nil, nil, nil

createBtn("Ghim Vị Trí", function(s) ghimActive = s; if s and lp.Character then lockedPos = lp.Character.HumanoidRootPart.CFrame end end)
createBtn("Xray ESP", function(s) xrayActive = s end)
createBtn("Ghost Mode", function(s)
    ghostActive = s
    if s and lp.Character then
        lp.Character.Archivable = true; ghostModel = lp.Character:Clone(); ghostModel.Parent = workspace
        for _, v in pairs(ghostModel:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false; v.Transparency = 0.5 end end
        workspace.CurrentCamera.CameraSubject = ghostModel:FindFirstChild("Humanoid")
    elseif ghostModel then ghostModel:Destroy(); workspace.CurrentCamera.CameraSubject = lp.Character.Humanoid end
end)
createBtn("Air Walk", function(s)
    airWalkActive = s
    if s then airWalkPart = Instance.new("Part", workspace); airWalkPart.Size = Vector3.new(15, 0.5, 15); airWalkPart.Anchored = true; airWalkPart.Transparency = 0.5
    elseif airWalkPart then airWalkPart:Destroy() end
end)

-- Heartbeat Loop
runService.Heartbeat:Connect(function(dt)
    if not lp.Character or not lp.Character:FindFirstChild("HumanoidRootPart") then return end
    local root = lp.Character.HumanoidRootPart
    
    if xrayActive then
        for _, p in pairs(game.Players:GetPlayers()) do
            if p ~= lp and p.Character and not p.Character:FindFirstChild("TrVuKhoaa_ESP") then
                local h = Instance.new("Highlight", p.Character); h.Name = "TrVuKhoaa_ESP"; h.FillColor = Color3.new(1, 0, 0)
            end
        end
    else
        for _, p in pairs(game.Players:GetPlayers()) do if p.Character and p.Character:FindFirstChild("TrVuKhoaa_ESP") then p.Character.TrVuKhoaa_ESP:Destroy() end end
    end

    if ghimActive and lockedPos and not ghostActive then root.CFrame = lockedPos; root.Velocity = Vector3.new(0,0,0) end
    if airWalkActive and airWalkPart then airWalkPart.Position = root.Position - Vector3.new(0, 3.5, 0) end
end)

