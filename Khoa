-- [[ LOGIC KÉO THẢ SIÊU CẤP (ANTI-LAG) ]]
local dragging, dragStart, startPos
TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
    end
end)

uis.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

-- Cập nhật vị trí bằng Heartbeat để mượt nhất có thể
runService.Heartbeat:Connect(function()
    if dragging then
        local delta = uis:GetMouseLocation() - Vector2.new(dragStart.X, dragStart.Y)
        -- Fix lệch tọa độ do IgnoreGuiInset
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y - 36)
    end
end)

-- [[ LOGIC ĐÓNG/MỞ TRIỆT ĐỂ ]]
local isOpen = true
ToggleBtn.MouseButton1Click:Connect(function()
    isOpen = not isOpen
    if not isOpen then
        -- Đóng: Ẩn nội dung ngay, thu nhỏ Frame
        Content.Visible = false
        SpeedBar.Visible = false
        MainFrame.Size = UDim2.new(0, 220, 0, 40)
        ToggleBtn.Text = "  ▶ Xray Controller"
    else
        -- Mở: Hiện Frame lớn, sau đó hiện nội dung
        MainFrame.Size = UDim2.new(0, 220, 0, 390)
        Content.Visible = true
        SpeedBar.Visible = true
        ToggleBtn.Text = "  ▼ Xray Controller"
    end
end)

-- Nút X (Xóa hẳn UI)
CloseBtn.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)

-- [[ VÒNG LẶP CHỨC NĂNG ]]
SpeedVal.FocusLost:Connect(function() currentSpeed = tonumber(SpeedVal.Text) or 1 end)

runService.Heartbeat:Connect(function(dt)
    local char = lp.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local root = char.HumanoidRootPart
    
    if localMoveDir.Magnitude > 0 then
        for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end
        local moveVec = (root.CFrame.LookVector * -localMoveDir.Z) + (root.CFrame.RightVector * localMoveDir.X) + (Vector3.new(0,1,0) * localMoveDir.Y)
        root.CFrame = root.CFrame + (moveVec.Unit * (currentSpeed * 50 * dt))
    end
    if ghimActive and lockedPos then root.CFrame = lockedPos; root.Velocity = Vector3.new(0,0,0) end
end)
