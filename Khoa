    local Tx = Instance.new("TextLabel", Frame); Tx.Text = "  "..text; Tx.Size = UDim2.new(1,0,1,-25); Tx.Position = UDim2.new(0,0,0,25); Tx.BackgroundTransparency = 1; Tx.TextColor3 = Color3.new(1,1,1); Tx.Font = Enum.Font.Antique; Tx.TextSize = 14; Tx.TextXAlignment = "Left"; Tx.TextWrapped = true
    task.delay(duration or 3, function() if Frame then Frame:Destroy() end end)
end

