-- [[ HÀM TẠO NÚT BẤM (STYLE CLASSIC) ]]
local function createBtn(parent, txt, isGrid, callback)
    local btn = Instance.new("TextButton", parent)
    btn.Size = isGrid and UDim2.new(1, 0, 1, 0) or UDim2.new(0.9, 0, 0, 32)
    btn.BackgroundTransparency = 1; btn.Text = ""
    
    local box = Instance.new("Frame", btn)
    box.Size = UDim2.new(0, 22, 0, 26); box.Position = UDim2.new(0, 5, 0.5, -13); box.BackgroundColor3 = Color3.fromRGB(22, 22, 22); box.BorderSizePixel = 0
    
    local lbl = Instance.new("TextLabel", btn)
    lbl.Size = UDim2.new(1, -35, 1, 0); lbl.Position = UDim2.new(0, 35, 0, 0); lbl.BackgroundTransparency = 1; lbl.Text = txt; lbl.TextColor3 = Color3.new(0.9, 0.9, 0.9); lbl.Font = Enum.Font.Antique; lbl.TextSize = 19; lbl.TextXAlignment = "Left"

    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        box.BackgroundColor3 = active and Color3.fromRGB(150, 150, 150) or Color3.fromRGB(22, 22, 22)
        callback(active)
    end)
end

