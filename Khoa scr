runService.RenderStepped:Connect(function(dt)
    local cur = os.clock()
    if fpsActive then fCount = fCount + 1; if cur - lastTick >= 1 then FpsLabel.Text = "FPS: " .. fCount; fCount = 0; lastTick = cur end end
    
    if thirdPersonActive then
        lp.CameraMaxZoomDistance = 128
        lp.CameraMinZoomDistance = 0.5
    end

    -- CHẠY CACHE QUÉT SILENT AIM 
    if silentAimActive then
        currentSilentAimTarget = getNearestTarget()
    else
        currentSilentAimTarget = nil
    end

    -- Vòng lặp cập nhật Hitbox Đầu Kéo Dài (Cột)
    if hitboxActive then
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= lp and v.Character and v.Character:FindFirstChild("Head") and v.Character:FindFirstChild("Humanoid") and v.Character.Humanoid.Health > 0 then
                local head = v.Character.Head
                head.Size = Vector3.new(currentHitboxSize, currentHitboxSize * 2.5, currentHitboxSize)
                head.Transparency = 1 
                head.CanCollide = false 
                head.Massless = true 
                if not head:FindFirstChild("VuKhoa_Hitbox_Tag") then
                    head.CustomPhysicalProperties = PhysicalProperties.new(0, 0, 0, 0, 0)
                    local tag = Instance.new("BoolValue", head)
                    tag.Name = "VuKhoa_Hitbox_Tag"
                end
            end
        end
    end
    
    local char = lp.Character; if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    -- Xử lý Hồn
    local realHum = char:FindFirstChild("Humanoid")
    if ghostActive and ghostModel and realHum then
        local ghostRoot = ghostModel:FindFirstChild("HumanoidRootPart")
        local ghostHum = ghostModel:FindFirstChild("Humanoid")
        if ghostRoot and ghostHum then
            local moveDir = realHum.MoveDirection
            if moveDir.Magnitude > 0 then
                ghostHum:Move(moveDir, false)
                if currentWalkSpeedLevel > 1 then
                    local speedMultiplier = (currentWalkSpeedLevel * 25) * dt
                    local flatDir = Vector3.new(moveDir.X, 0, moveDir.Z)
                    ghostRoot.CFrame = ghostRoot.CFrame + (flatDir * speedMultiplier)
                end
                local flatDir = Vector3.new(moveDir.X, 0, moveDir.Z)
                if flatDir.Magnitude > 0.001 then
                    ghostRoot.CFrame = CFrame.lookAt(ghostRoot.Position, ghostRoot.Position + flatDir)
                end
            end
        end
    end
    
    local target = char.HumanoidRootPart
    local currentHum = realHum
    
    if currentHum and not ghostActive then
        if currentHum.WalkSpeed < 16 then currentHum.WalkSpeed = 16 end
        
        if currentWalkSpeedLevel > 1 and localMoveDir.Magnitude == 0 and currentHum.MoveDirection.Magnitude > 0 then
            local speedMultiplier = (currentWalkSpeedLevel * 25) * dt
            target.CFrame = target.CFrame + (currentHum.MoveDirection * speedMultiplier)
            for _, track in pairs(currentHum:GetPlayingAnimationTracks()) do track:AdjustSpeed(0.25) end
        end
        
        if currentHum.JumpPower < 50 then currentHum.JumpPower = 50 end
        currentHum.Sit = false
    end
    
    for _, v in pairs(target.Parent:GetDescendants()) do
        if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" and v.Anchored then v.Anchored = false end
    end

    -- LOGIC CONTROLLER
    if not ghostActive then
        local joystickDir = currentHum and currentHum.MoveDirection or Vector3.zero
        
        if localMoveDir.Magnitude > 0 or (moveModeFace and joystickDir.Magnitude > 0 and localMoveDir.Magnitude > 0) then
            if not wasMoving then wasMoving = true end

            local bv = target:FindFirstChild("VuKhoa_Fly") or Instance.new("BodyVelocity")
            bv.Name = "VuKhoa_Fly"
            bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            
            local mv = Vector3.zero
            if moveModeFace then
                local camLook = cam.CFrame.LookVector
                local camRight = cam.CFrame.RightVector
                local fwd = Vector3.new(camLook.X, 0, camLook.Z).Unit
                local rht = Vector3.new(camRight.X, 0, camRight.Z).Unit
                if fwd.Magnitude < 0.001 then fwd = Vector3.new(0,0,-1); rht = Vector3.new(1,0,0) end
                
                local uiMv = (fwd * -localMoveDir.Z) + (rht * localMoveDir.X) + (Vector3.new(0,1,0) * localMoveDir.Y)
                mv = uiMv + joystickDir
            else
                local fwd = Vector3.new(0, 0, -1); local rht = Vector3.new(1, 0, 0)
                mv = (fwd * -localMoveDir.Z) + (rht * localMoveDir.X) + (Vector3.new(0,1,0) * localMoveDir.Y)
            end
            
            lastMv = mv
            
            if mv.Magnitude > 0 then bv.Velocity = mv.Unit * (currentSpeed * 50) else bv.Velocity = Vector3.zero end
            bv.Parent = target
            
            local bg = target:FindFirstChild("VuKhoa_Gyro") or Instance.new("BodyGyro")
            bg.Name = "VuKhoa_Gyro"; bg.P = 50000
            
            if moveModeFace then
                bg.MaxTorque = Vector3.new(math.huge, 0, math.huge)
                bg.CFrame = CFrame.new() 
                if mv.X ~= 0 or mv.Z ~= 0 then
                    local flatMv = Vector3.new(mv.X, 0, mv.Z)
                    if flatMv.Magnitude > 0.001 then target.CFrame = CFrame.lookAt(target.Position, target.Position + flatMv) end
                end
            else
                bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
                local flatMv = Vector3.new(mv.X, 0, mv.Z)
                if flatMv.Magnitude > 0.001 then bg.CFrame = CFrame.lookAt(Vector3.zero, flatMv) else bg.CFrame = CFrame.lookAt(Vector3.zero, Vector3.new(0,0,-1)) end
            end
            bg.Parent = target

            if currentHum then currentHum:ChangeState(Enum.HumanoidStateType.Freefall) end
        else
            local bv = target:FindFirstChild("VuKhoa_Fly"); if bv then bv:Destroy() end
            local bg = target:FindFirstChild("VuKhoa_Gyro"); if bg then bg:Destroy() end
            
            if wasMoving then
                wasMoving = false
                if lastMv.X ~= 0 or lastMv.Z ~= 0 then
                    local flatMv = Vector3.new(lastMv.X, 0, lastMv.Z)
                    if flatMv.Magnitude > 0.001 then target.CFrame = CFrame.lookAt(target.Position, target.Position + flatMv.Unit) end
                end
            end

            if not noclipActive then 
                for _, v in pairs(target.Parent:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = true end end 
            end
        end
    end
    
    if ghimActive and lockedPos and not ghostActive then char.HumanoidRootPart.CFrame = lockedPos; char.HumanoidRootPart.Velocity = Vector3.zero end
    if spinBotActive and not ghostActive then target.CFrame = target.CFrame * CFrame.Angles(0, math.rad(50), 0) end

    local pCount = 0; local bC = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y)
    
    for p, data in pairs(espCache) do
        if not p or not p.Parent then
            data.Box:Destroy()
            data.Line:Destroy()
            espCache[p] = nil
        end
    end

    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
            pCount = pCount + 1; local eChar = p.Character; local eRoot = eChar.HumanoidRootPart
            if xrayActive then local h = eChar:FindFirstChild("TrVuKhoaa_ESP") or Instance.new("Highlight", eChar); h.FillColor = IOS_BLUE; h.Name = "TrVuKhoaa_ESP" else local h = eChar:FindFirstChild("TrVuKhoaa_ESP"); if h then h:Destroy() end end
            local espData = getESP(p); local hP, hV = cam:WorldToViewportPoint(eRoot.Position + Vector3.new(0, 3.5, 0)); local fP, fV = cam:WorldToViewportPoint(eRoot.Position - Vector3.new(0, 3.5, 0))
            if hV or fV then
                if espBoxActive then local h = math.abs(hP.Y - fP.Y); local w = h * 0.6; espData.Box.Size = UDim2.new(0, w, 0, h); espData.Box.Position = UDim2.new(0, hP.X - w/2, 0, hP.Y); espData.Box.Visible = true else espData.Box.Visible = false end
                if espLineActive then local pP = Vector2.new(fP.X, fP.Y); local d = (bC - pP).Magnitude; espData.Line.Size = UDim2.new(0, d, 0, 1.5); espData.Line.Position = UDim2.new(0, (bC.X + pP.X)/2, 0, (bC.Y + pP.Y)/2); espData.Line.Rotation = math.deg(math.atan2(pP.Y - bC.Y, pP.X - bC.X)); espData.Line.Visible = true else espData.Line.Visible = false end
            else espData.Box.Visible = false; espData.Line.Visible = false end
        else if espCache[p] then espCache[p].Box.Visible = false; espCache[p].Line.Visible = false end end
    end
    if espCountActive then CountLabel.Text = "Địch: " .. pCount end
end)

