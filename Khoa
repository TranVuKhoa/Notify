-- 4. LOGIC KÉO THẢ ICON & MỞ POP-UP
local dragging = false
local dragStart, startPos

FloatingFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = FloatingFrame.Position
    end
end)

uis.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        FloatingFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

FloatingFrame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
        if (input.Position - dragStart).Magnitude < 5 then -- Nếu chỉ chạm (không kéo)
            MainMenu.Visible = not MainMenu.Visible
            MainMenu.Position = UDim2.new(FloatingFrame.Position.X.Scale, FloatingFrame.Position.X.Offset + 65, FloatingFrame.Position.Y.Scale, FloatingFrame.Position.Y.Offset - 150)
        end
    end
end)

-- 5. VÒNG LẶP HEARTBEAT
runService.Heartbeat:Connect(function(dt)
    local char = lp.Character; if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local root = char.HumanoidRootPart
    if xrayActive then
        for _, p in pairs(game.Players:GetPlayers()) do
            if p ~= lp and p.Character then
                local h = p.Character:FindFirstChild("VK_ESP") or Instance.new("Highlight", p.Character)
                h.Name = "VK_ESP"; h.FillColor = Color3.fromRGB(88, 101, 242)
            end
        end
    end
    local target = (ghostActive and ghostModel) and ghostModel:FindFirstChild("HumanoidRootPart") or root
    if localMoveDir.Magnitude > 0 then
        for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end
        local cam = workspace.CurrentCamera
        local moveVec = (cam.CFrame.LookVector * -localMoveDir.Z) + (cam.CFrame.RightVector * localMoveDir.X) + (Vector3.new(0,1,0) * localMoveDir.Y)
        if moveVec.Magnitude > 0 then target.CFrame = target.CFrame + (moveVec.Unit * (currentSpeed * 50 * dt)) end
    end
    if ghimActive and lockedPos and not ghostActive then root.CFrame = lockedPos; root.Velocity = Vector3.zero end
    if ghostActive then root.CFrame = lockedPos or root.CFrame; root.Velocity = Vector3.zero end
    if airWalkActive and airWalkPart then airWalkPart.Position = target.Position - Vector3.new(0, 3.5, 0) end
end)

