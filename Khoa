-- Hàm tạo nút phong cách Android
local function AddToggle(name, default, callback)
    local Bg = Instance.new("TextButton", Content)
    Bg.Size = UDim2.new(0.95, 0, 0, 35); Bg.BackgroundColor3 = Color3.fromRGB(25, 25, 25); Bg.Text = ""
    Instance.new("UICorner", Bg)
    
    local Label = Instance.new("TextLabel", Bg); Label.Size = UDim2.new(1, -50, 1, 0); Label.Position = UDim2.new(0, 10, 0, 0); Label.Text = name; Label.TextColor3 = Color3.new(1,1,1); Label.Font = Enum.Font.Gotham; Label.TextSize = 13; Label.TextXAlignment = "Left"; Label.BackgroundTransparency = 1
    
    local Tgl = Instance.new("Frame", Bg); Tgl.Size = UDim2.new(0, 30, 0, 16); Tgl.Position = UDim2.new(1, -40, 0.5, -8); Tgl.BackgroundColor3 = default and Color3.fromRGB(88, 101, 242) or Color3.fromRGB(50, 50, 50); Instance.new("UICorner", Tgl).CornerRadius = UDim.new(1, 0)
    local Circle = Instance.new("Frame", Tgl); Circle.Size = UDim2.new(0, 12, 0, 12); Circle.Position = default and UDim2.new(1, -14, 0.5, -6) or UDim2.new(0, 2, 0.5, -6); Circle.BackgroundColor3 = Color3.new(1,1,1); Instance.new("UICorner", Circle).CornerRadius = UDim.new(1, 0)

    local active = default
    Bg.MouseButton1Click:Connect(function()
        active = not active
        Tgl.BackgroundColor3 = active and Color3.fromRGB(88, 101, 242) or Color3.fromRGB(50, 50, 50)
        Circle:TweenPosition(active and UDim2.new(1, -14, 0.5, -6) or UDim2.new(0, 2, 0.5, -6), "Out", "Quad", 0.2, true)
        callback(active)
        if notifyEnabled then SendNotify("System", name..": "..(active and "ON" or "OFF")) end
    end)
end

