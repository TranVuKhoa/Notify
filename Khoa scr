--- [Chú thích: VÒNG LẶP CHÍNH CỦA GAME (Tính toán RenderStepped cho di chuyển, Ghost, ESP)]
runService.RenderStepped:Connect(function(dt)
    -- Hiển thị FPS
    local cur = os.clock()
    if fpsActive then fCount = fCount + 1; if cur - lastTick >= 1 then RegLang(FpsLabel, "Text", "FPS: " .. fCount, "FPS: " .. fCount); fCount = 0; lastTick = cur end end
    if thirdPersonActive then lp.CameraMode = Enum.CameraMode.Classic; lp.CameraMinZoomDistance = 15 end
    
    local char = lp.Character; if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local realHum = char:FindFirstChild("Humanoid"); local target = char.HumanoidRootPart; local currentHum = realHum
    
    if currentHum then 
        -- Logic Độn thổ
        currentHum.AutoRotate = not (spinBotActive or moonwalkActive or isFleeing)
        if upDownActive and not isFleeing then
            if upDownMode == "Up" then currentHum.CameraOffset = Vector3.zero elseif upDownMode == "Down" then currentHum.CameraOffset = Vector3.new(0, 14, 0) end
            local params = RaycastParams.new(); params.FilterDescendantsInstances = {lp.Character, ghostModel}; params.FilterType = Enum.RaycastFilterType.Exclude; params.IgnoreWater = true
            local rayStartOffset = (upDownMode == "Down") and 30 or 10; local origin = Vector3.new(target.Position.X, target.Position.Y + rayStartOffset, target.Position.Z)
            local result = workspace:Raycast(origin, Vector3.new(0, -100, 0), params)
            if result then local destY = result.Position.Y + (upDownMode == "Down" and -13 or 15); local rx, ry, rz = target.CFrame:ToOrientation(); target.CFrame = CFrame.new(target.Position.X, destY, target.Position.Z) * CFrame.Angles(rx, ry, rz); target.Velocity = Vector3.new(target.Velocity.X, 0, target.Velocity.Z) end
            if currentHum:GetState() == Enum.HumanoidStateType.Freefall then currentHum:ChangeState(Enum.HumanoidStateType.RunningNoPhysics) end
        else currentHum.CameraOffset = Vector3.zero end

        -- Cập nhật tốc độ dựa vào thông số đã hack
        if multiSpeedActive then currentHum.WalkSpeed = baseWalkSpeed * multiVal end
        if multiJumpActive then 
            if currentHum.UseJumpPower then currentHum.JumpPower = baseJumpPower * multiVal
            else currentHum.JumpHeight = baseJumpHeight * multiVal end
        end
    end
    
    -- Logic của Xác ma (Ghost Mode)
    if (ghostActive or fakeLagActive or bypassTeleportActive) and ghostModel and realHum then
        local ghostRoot = ghostModel:FindFirstChild("HumanoidRootPart"); local ghostHum = ghostModel:FindFirstChild("Humanoid")
        if ghostRoot and ghostHum then
            local moveDir = Vector3.zero
            if getMoveVector then
                local mv = getMoveVector()
                if mv.Magnitude > 0 then
                    local fwd = Vector3.new(cam.CFrame.LookVector.X, 0, cam.CFrame.LookVector.Z)
                    if fwd.Magnitude > 0.001 then fwd = fwd.Unit else fwd = Vector3.new(0,0,-1) end
                    local rht = Vector3.new(cam.CFrame.RightVector.X, 0, cam.CFrame.RightVector.Z)
                    if rht.Magnitude > 0.001 then rht = rht.Unit else rht = Vector3.new(1,0,0) end
                    moveDir = (fwd * -mv.Z) + (rht * mv.X)
                    if moveDir.Magnitude > 0 then moveDir = moveDir.Unit end
                end
            else moveDir = realHum.MoveDirection end

            -- Animation của xác ma
            local isMoving = moveDir.Magnitude > 0
            local ghostState = ghostHum:GetState()
            local targetGhostSpeed = (currentWalkSpeedLevel > 1) and animSpeed or 1

            if ghostState == Enum.HumanoidStateType.Freefall then
                if ghostAnimTracks.Jump and ghostAnimTracks.Jump.IsPlaying then ghostAnimTracks.Jump:Stop() end
                if ghostAnimTracks.Idle and ghostAnimTracks.Idle.IsPlaying then ghostAnimTracks.Idle:Stop() end
                if ghostAnimTracks.Walk and ghostAnimTracks.Walk.IsPlaying then ghostAnimTracks.Walk:Stop() end
                if ghostAnimTracks.Fall and not ghostAnimTracks.Fall.IsPlaying then ghostAnimTracks.Fall:Play() end
            elseif ghostState == Enum.HumanoidStateType.Jumping then
                if ghostAnimTracks.Idle and ghostAnimTracks.Idle.IsPlaying then ghostAnimTracks.Idle:Stop() end
                if ghostAnimTracks.Walk and ghostAnimTracks.Walk.IsPlaying then ghostAnimTracks.Walk:Stop() end
                if ghostAnimTracks.Fall and ghostAnimTracks.Fall.IsPlaying then ghostAnimTracks.Fall:Stop() end
                if ghostAnimTracks.Jump and not ghostAnimTracks.Jump.IsPlaying then ghostAnimTracks.Jump:Play() end
            else
                if ghostAnimTracks.Jump and ghostAnimTracks.Jump.IsPlaying then ghostAnimTracks.Jump:Stop() end
                if ghostAnimTracks.Fall and ghostAnimTracks.Fall.IsPlaying then ghostAnimTracks.Fall:Stop() end
                
                if isMoving then
                    if ghostAnimTracks.Idle and ghostAnimTracks.Idle.IsPlaying then ghostAnimTracks.Idle:Stop() end
                    if ghostAnimTracks.Walk and not ghostAnimTracks.Walk.IsPlaying then ghostAnimTracks.Walk:Play() end
                    if ghostAnimTracks.Walk then ghostAnimTracks.Walk:AdjustSpeed(targetGhostSpeed) end
                else
                    if ghostAnimTracks.Walk and ghostAnimTracks.Walk.IsPlaying then ghostAnimTracks.Walk:Stop() end
                    if ghostAnimTracks.Idle and not ghostAnimTracks.Idle.IsPlaying then ghostAnimTracks.Idle:Play() end
                end
            end

            if moveDir.Magnitude > 0 then
                ghostHum:Move(moveDir, false)
                if currentWalkSpeedLevel > 1 then local speedMultiplier = (currentWalkSpeedLevel * 25) * dt; local flatDir = Vector3.new(moveDir.X, 0, moveDir.Z); ghostRoot.CFrame = ghostRoot.CFrame + (flatDir * speedMultiplier) end
                local flatDir = Vector3.new(moveDir.X, 0, moveDir.Z)
                if flatDir.Magnitude > 0.001 then if moonwalkActive then ghostRoot.CFrame = CFrame.lookAt(ghostRoot.Position, ghostRoot.Position - flatDir) else ghostRoot.CFrame = CFrame.lookAt(ghostRoot.Position, ghostRoot.Position + flatDir) end end 
            else
                ghostHum:Move(Vector3.zero, false); ghostRoot.Velocity = Vector3.new(0, ghostRoot.Velocity.Y, 0)
            end
        end
    end
    
    if currentHum and not ghostActive and not fakeLagActive and not bypassTeleportActive and not isFleeing then
        if not multiSpeedActive and currentHum.WalkSpeed < 16 then currentHum.WalkSpeed = 16 end
        
