local function applyGodMode1(char)
    if not char then return end
    local hum = char:WaitForChild("Humanoid", 3)
    local hrp = char:WaitForChild("HumanoidRootPart", 3)
    if not hum then return end
    if godModeConn then godModeConn:Disconnect(); godModeConn = nil end
    if loopHealConn then loopHealConn:Disconnect(); loopHealConn = nil end
    if antiVoidConn then antiVoidConn:Disconnect(); antiVoidConn = nil end
    hum.MaxHealth = math.huge
    hum.Health = math.huge
    godModeConn = hum:GetPropertyChangedSignal("Health"):Connect(function()
        if godMode1Active then hum.Health = hum.MaxHealth end
    end)
    loopHealConn = runService.Heartbeat:Connect(function()
        if godMode1Active and hum and hum.Parent then hum.Health = hum.MaxHealth end
    end)
    if hrp then
        antiVoidConn = runService.Heartbeat:Connect(function()
            if godMode1Active and hrp and hrp.Parent then
                if hrp.Position.Y < -200 then hrp.CFrame = CFrame.new(hrp.Position.X, 100, hrp.Position.Z); hrp.Velocity = Vector3.zero end
            end
        end)
    end
    pcall(function()
        local dMod = rs:FindFirstChild("Effect") and rs.Effect:FindFirstChild("Container") and rs.Effect.Container:FindFirstChild("Death")
        if dMod then hookfunction(require(dMod), function() end) end
    end)
end

