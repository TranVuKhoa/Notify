createBtn(L, "Xray ESP", false, function(s) xrayActive = s end)

-- [[ KÉO THẢ (DÙNG CHO TITLEBAR) ]]
local dragging, dragStart, startPos
TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = MainFrame.Position
    end
end)
uis.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
uis.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

-- [[ ĐÓNG MỞ (CHỐNG BIẾN MẤT) ]]
local open = true
ToggleBtn.MouseButton1Click:Connect(function()
    open = not open
    if not open then
        Container.Visible = false
        MainFrame.Size = UDim2.new(0, 220, 0, 40)
        ToggleBtn.Text = "  ▶ Xray Controller"
    else
        MainFrame.Size = UDim2.new(0, 220, 0, 395)
        Container.Visible = true
        ToggleBtn.Text = "  ▼ Xray Controller"
    end
end)

-- [[ HEARTBEAT LOOP ]]
SpeedVal.FocusLost:Connect(function() currentSpeed = tonumber(SpeedVal.Text) or 1 end)
runService.Heartbeat:Connect(function(dt)
    local char = lp.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local root = char.HumanoidRootPart
        if localMoveDir.Magnitude > 0 then
            for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end
            local moveVec = (root.CFrame.LookVector * -localMoveDir.Z) + (root.CFrame.RightVector * localMoveDir.X) + (Vector3.new(0,1,0) * localMoveDir.Y)
            root.CFrame = root.CFrame + (moveVec.Unit * (currentSpeed * 50 * dt))
        end
        if ghimActive and lockedPos then root.CFrame = lockedPos; root.Velocity = Vector3.new(0,0,0) end
    end
end)
