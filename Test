local function CreateNotify(title, text, duration)
    local sg = Instance.new("ScreenGui", game.CoreGui)
    local mf = Instance.new("Frame", sg)
    mf.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    mf.Size = UDim2.new(0, 260, 0, 70)
    mf.Position = UDim2.new(1, 10, 1, -100)
    Instance.new("UICorner", mf).CornerRadius = UDim.new(0, 6)
    local s = Instance.new("UIStroke", mf)
    s.Color = Color3.fromRGB(255, 255, 0); s.Thickness = 2

    local tl = Instance.new("TextLabel", mf)
    tl.Text = title; tl.TextColor3 = Color3.new(1, 1, 0); tl.Size = UDim2.new(1, -20, 0, 25); tl.Position = UDim2.new(0, 10, 0, 5); tl.BackgroundTransparency = 1; tl.Font = "GothamBold"; tl.TextSize = 14; tl.TextXAlignment = "Left"

    local cl = Instance.new("TextLabel", mf)
    cl.Text = text; cl.TextColor3 = Color3.new(1, 1, 1); cl.Size = UDim2.new(1, -20, 0, 35); cl.Position = UDim2.new(0, 10, 0, 30); cl.BackgroundTransparency = 1; cl.Font = "Gotham"; cl.TextSize = 13; cl.TextXAlignment = "Left"; cl.TextWrapped = true

    mf:TweenPosition(UDim2.new(1, -270, 1, -100), "Out", "Back", 0.5, true)
    task.delay(duration or 5, function()
        if mf then
            mf:TweenPosition(UDim2.new(1, 10, 1, -100), "In", "Quad", 0.5, true, function() sg:Destroy() end)
        end
    end)
end

