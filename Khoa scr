local mapCache = {}
local deleteWallLoop = nil
local function DoDeleteWall(v)
    if v:IsA("BasePart") and not v:IsA("Terrain") then
        local isChar = false; local p = v.Parent
        while p and p ~= workspace do if p:FindFirstChild("Humanoid") then isChar = true; break end; p = p.Parent end
        if not isChar then
            local n = v.Name:lower()
            if n:match("floor") or n:match("base") or n:match("ground") or n:match("spawn") or n:match("terrain") then return end
            local sx, sy, sz = v.Size.X, v.Size.Y, v.Size.Z
            local isGround = (sx >= 15 and sz >= 15 and sy <= sx and sy <= sz) or (sx > 150 and sz > 150)
