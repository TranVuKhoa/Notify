local OrigTrans = {}
local OrigHitboxData = {}

local function RevertLocalPlayer()
    pcall(function()
        if player.Character and player.Character:FindFirstChild("Humanoid") then
            local h = player.Character.Humanoid
            h.AutoRotate = true
            h.CameraOffset = Vector3.new(0,0,0)
        end
        if player.Character then
            local hrp = player.Character:FindFirstChild("HumanoidRootPart")
            if hrp then 
                local bav = hrp:FindFirstChild("SpinBotBav")
                if bav then bav:Destroy() end
            end
            
            local joint = hrp and hrp:FindFirstChild("RootJoint")
            if not joint and player.Character:FindFirstChild("LowerTorso") then
                joint = player.Character.LowerTorso:FindFirstChild("Root")
            end
            if joint and OrigTrans["RootJointC0"] then
                joint.C0 = OrigTrans["RootJointC0"]
            end
            
            for _, v in pairs(player.Character:GetDescendants()) do
                if OrigTrans[v] then v.Transparency = OrigTrans[v] end
            end
        end
        player.CameraMode = Enum.CameraMode.Classic
        player.CameraMinZoomDistance = 0.5; player.CameraMaxZoomDistance = 400
    end)
end

local function RevertAllEnemies()
    pcall(function()
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Character then
                local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                if hrp and OrigHitboxData[hrp] then
                    hrp.Size = OrigHitboxData[hrp].Size
                    hrp.Transparency = OrigHitboxData[hrp].Trans
                    hrp.CanCollide = OrigHitboxData[hrp].Collide
                    hrp.Massless = OrigHitboxData[hrp].Massless
                    OrigHitboxData[hrp] = nil
                end
                if hrp then hrp.AssemblyLinearVelocity = Vector3.new(0,0,0) end
            end
        end
    end)
end

local function MasterRevert()
    RevertLocalPlayer()
    RevertAllEnemies()
    fovCircle.Visible = false
    enemyCountLbl.Visible = false
end

