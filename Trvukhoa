local function UpdateLang()
    local isVN = (Cfg.Language == "VN")
    for _, it in ipairs(LangData.labels) do
        it.l.Text = isVN and it.v or it.e
    end
    for _, it in ipairs(LangData.buttons) do
        if it.update then it.update() else it.l.Text = isVN and it.v or it.e end
    end
    for _, it in ipairs(LangData.toggles) do
        local base = isVN and it.v or it.e
        local stateOn = isVN and " [BẬT]" or " [ON]"
        local stateOff = isVN and " [TẮT]" or " [OFF]"
        it.l.Text = base .. (Cfg[it.flag] and stateOn or stateOff)
    end
    for _, it in ipairs(LangData.tabs) do
        it.l.Text = isVN and it.v or it.e
    end
    for _, it in ipairs(LangData.headers) do
        it.t.Text = isVN and it.tv or it.te
        it.d.Text = isVN and it.dv or it.de
    end
end

