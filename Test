local function createBtn(txt, callback)
    local btn = Instance.new("TextButton", Content)
    btn.Size = UDim2.new(0.92, 0, 0, 38); btn.BackgroundTransparency = 1; btn.Text = ""
    local bg = Instance.new("Frame", btn)
    bg.Size = UDim2.new(1, 0, 1, 0); bg.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 6)
    local box = Instance.new("Frame", btn)
    box.Size = UDim2.new(0, 16, 0, 16); box.Position = UDim2.new(0, 12, 0.5, -8); box.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 4)
    local lbl = Instance.new("TextLabel", btn)
    lbl.Text = txt; lbl.Size = UDim2.new(1, -40, 1, 0); lbl.Position = UDim2.new(0, 40, 0, 0); lbl.BackgroundTransparency = 1; lbl.TextColor3 = Color3.new(0.8, 0.8, 0.8); lbl.Font = "Gotham"; lbl.TextSize = 13; lbl.TextXAlignment = "Left"

    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        box.BackgroundColor3 = active and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(40, 40, 40)
        lbl.TextColor3 = active and Color3.new(1, 1, 1) or Color3.new(0.8, 0.8, 0.8)
        callback(active)
        CreateNotify("VKhoa Sync", txt.." : "..(active and "BẬT" or "TẮT"), 2)
    end)
end

