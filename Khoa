-- [[ TÍNH NĂNG MỞ MENU 3 NGÓN / ẨN FLOATING 4 NGÓN ]]
local activeTouches = {}
local TOUCH_THRESHOLD = 0.25 

uis.InputBegan:Connect(function(input, gpe)
    if input.UserInputType == Enum.UserInputType.Touch then
        activeTouches[input] = os.clock()
        
        task.delay(0.05, function()
            local count = 0
            local minTime = math.huge
            local maxTime = 0
            
            for _, timeStart in pairs(activeTouches) do
                count = count + 1
                if timeStart < minTime then minTime = timeStart end
                if timeStart > maxTime then maxTime = timeStart end
            end
            
            local isSimultaneous = (maxTime - minTime) <= TOUCH_THRESHOLD
            
            if isSimultaneous then
                if count == 3 then
                    ToggleMenu()
                    activeTouches = {}
                elseif count == 4 then
                    OpenBtn.Visible = not OpenBtn.Visible
                    SendNotify("Hệ Thống", OpenBtn.Visible and "Đã hiện nút Floating" or "Đã ẩn nút Floating", 2)
                    activeTouches = {}
                end
            end
        end)
    end
end)

uis.InputEnded:Connect(function(input, gpe)
    if input.UserInputType == Enum.UserInputType.Touch then
        activeTouches[input] = nil
    end
end)

