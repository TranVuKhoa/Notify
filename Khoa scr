    grip.Text = "" 
    grip.ZIndex = 50

    local bar1 = Instance.new("Frame", grip)
    bar1.Size = UDim2.new(0, 16, 0, 4)
    bar1.AnchorPoint = Vector2.new(0.5, 0.5)
    bar1.Position = UDim2.new(1, -16, 1, -16)
    bar1.BackgroundColor3 = IOS_BLUE
    bar1.Rotation = -45
    Instance.new("UICorner", bar1).CornerRadius = UDim.new(1, 0)

    local bar2 = Instance.new("Frame", grip)
    bar2.Size = UDim2.new(0, 8, 0, 4)
    bar2.AnchorPoint = Vector2.new(0.5, 0.5)
    bar2.Position = UDim2.new(1, -10, 1, -10)
    bar2.BackgroundColor3 = IOS_BLUE
    bar2.Rotation = -45
    Instance.new("UICorner", bar2).CornerRadius = UDim.new(1, 0)

    local dragging = false
    local dragStart = nil
    local startSize = nil

    grip.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startSize = frame.AbsoluteSize
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)

    uis.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            local newWidth = math.clamp(startSize.X + delta.X, minSize.X, maxSize.X)
            local newHeight = math.clamp(startSize.Y + delta.Y, minSize.Y, maxSize.Y)
            local newSize = UDim2.new(0, newWidth, 0, newHeight)
            frame.Size = newSize
            if onResize then onResize(newSize) end 
        end
    end)
    return grip
end

