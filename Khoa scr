local lastTick, fCount = os.clock(), 0

runService.RenderStepped:Connect(function(dt)
    local cur = os.clock()
    if fpsActive then fCount = fCount + 1; if cur - lastTick >= 1 then FpsLabel.Text = "FPS: " .. fCount; fCount = 0; lastTick = cur end end
    if thirdPersonActive then lp.CameraMode = Enum.CameraMode.Classic; lp.CameraMinZoomDistance = 15 end
    
    local char = lp.Character; if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local realHum = char:FindFirstChild("Humanoid"); local target = char.HumanoidRootPart; local currentHum = realHum
    
    if currentHum then 
        currentHum.AutoRotate = not (spinBotActive or moonwalkActive)
        
        if upDownActive then
            if upDownMode == "Up" then
                currentHum.CameraOffset = Vector3.zero
            elseif upDownMode == "Down" then
                currentHum.CameraOffset = Vector3.new(0, 14, 0)
            end

            local params = RaycastParams.new()
            params.FilterDescendantsInstances = {lp.Character, ghostModel}
            params.FilterType = Enum.RaycastFilterType.Exclude
            params.IgnoreWater = true

            local rayStartOffset = (upDownMode == "Down") and 30 or 10
            local origin = Vector3.new(target.Position.X, target.Position.Y + rayStartOffset, target.Position.Z)
            local result = workspace:Raycast(origin, Vector3.new(0, -100, 0), params)

            if result then
                local destY = result.Position.Y + (upDownMode == "Down" and -13 or 15)
                local rx, ry, rz = target.CFrame:ToOrientation()
                target.CFrame = CFrame.new(target.Position.X, destY, target.Position.Z) * CFrame.Angles(rx, ry, rz)
                target.Velocity = Vector3.new(target.Velocity.X, 0, target.Velocity.Z)
            end
            if currentHum:GetState() == Enum.HumanoidStateType.Freefall then currentHum:ChangeState(Enum.HumanoidStateType.RunningNoPhysics) end
        else
            currentHum.CameraOffset = Vector3.zero
        end
    end
    
    if ghostActive and ghostModel and realHum then
        local ghostRoot = ghostModel:FindFirstChild("HumanoidRootPart"); local ghostHum = ghostModel:FindFirstChild("Humanoid")
        if ghostRoot and ghostHum then
            local moveDir = Vector3.zero
            if getMoveVector then
                local mv = getMoveVector()
                if mv.Magnitude > 0 then
                    local fwd = Vector3.new(cam.CFrame.LookVector.X, 0, cam.CFrame.LookVector.Z)
                    if fwd.Magnitude > 0.001 then fwd = fwd.Unit else fwd = Vector3.new(0,0,-1) end
                    local rht = Vector3.new(cam.CFrame.RightVector.X, 0, cam.CFrame.RightVector.Z)
                    if rht.Magnitude > 0.001 then rht = rht.Unit else rht = Vector3.new(1,0,0) end
                    moveDir = (fwd * -mv.Z) + (rht * mv.X)
                    if moveDir.Magnitude > 0 then moveDir = moveDir.Unit end
                end
            else
                moveDir = realHum.MoveDirection
            end

            if moveDir.Magnitude > 0 then
                ghostHum:Move(moveDir, false)
                if currentWalkSpeedLevel > 1 then 
                    local speedMultiplier = (currentWalkSpeedLevel * 25) * dt
                    local flatDir = Vector3.new(moveDir.X, 0, moveDir.Z)
                    ghostRoot.CFrame = ghostRoot.CFrame + (flatDir * speedMultiplier) 
                end
                local flatDir = Vector3.new(moveDir.X, 0, moveDir.Z)
                if flatDir.Magnitude > 0.001 then 
                    if moonwalkActive then ghostRoot.CFrame = CFrame.lookAt(ghostRoot.Position, ghostRoot.Position - flatDir) 
                    else ghostRoot.CFrame = CFrame.lookAt(ghostRoot.Position, ghostRoot.Position + flatDir) end
                end 
            else
                ghostHum:Move(Vector3.zero, false)
                ghostRoot.Velocity = Vector3.new(0, ghostRoot.Velocity.Y, 0)
            end
        end
    end
    
    if currentHum and not ghostActive then
        if currentHum.WalkSpeed < 16 then currentHum.WalkSpeed = 16 end
        if currentWalkSpeedLevel > 1 and localMoveDir.Magnitude == 0 and currentHum.MoveDirection.Magnitude > 0 then local speedMultiplier = (currentWalkSpeedLevel * 25) * dt; target.CFrame = target.CFrame + (currentHum.MoveDirection * speedMultiplier); for _, track in pairs(currentHum:GetPlayingAnimationTracks()) do track:AdjustSpeed(0.25) end end
        if currentHum.JumpPower < 50 then currentHum.JumpPower = 50 end; currentHum.Sit = false
    end
    
    for _, v in pairs(target.Parent:GetDescendants()) do if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" and v.Anchored then v.Anchored = false end end

    if not ghostActive then
        local joystickDir = currentHum and currentHum.MoveDirection or Vector3.zero
        local isControllerMoving = localMoveDir.Magnitude > 0
        local mv = Vector3.zero
        
        if isControllerMoving then
            if not wasMoving then wasMoving = true end
            local bv = target:FindFirstChild("VuKhoa_Fly") or Instance.new("BodyVelocity"); bv.Name = "VuKhoa_Fly"; bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            if moveModeFace then
                local camLook = cam.CFrame.LookVector; local camRight = cam.CFrame.RightVector; local fwd = Vector3.new(camLook.X, 0, camLook.Z).Unit; local rht = Vector3.new(camRight.X, 0, camRight.Z).Unit
                if fwd.Magnitude < 0.001 then fwd = Vector3.new(0,0,-1); rht = Vector3.new(1,0,0) end
                mv = (fwd * -localMoveDir.Z) + (rht * localMoveDir.X) + (Vector3.new(0,1,0) * localMoveDir.Y) + joystickDir
            else
                local fwd = Vector3.new(0, 0, -1); local rht = Vector3.new(1, 0, 0); mv = (fwd * -localMoveDir.Z) + (rht * localMoveDir.X) + (Vector3.new(0,1,0) * localMoveDir.Y)
            end
            lastMv = mv; if mv.Magnitude > 0 then bv.Velocity = mv.Unit * (currentSpeed * 50) else bv.Velocity = Vector3.zero end; bv.Parent = target
            if currentHum then currentHum:ChangeState(Enum.HumanoidStateType.Freefall) end
        else
            local bv = target:FindFirstChild("VuKhoa_Fly"); if bv then bv:Destroy() end
            if wasMoving then 
                wasMoving = false
                if lastMv.X ~= 0 or lastMv.Z ~= 0 then 
                    local flatMv = Vector3.new(lastMv.X, 0, lastMv.Z)
                    if flatMv.Magnitude > 0.001 then target.CFrame = CFrame.lookAt(target.Position, target.Position + flatMv.Unit) end 
                end 
            end
            if not noclipActive and not upDownActive then for i = 1, #charPartsCache do if charPartsCache[i] and charPartsCache[i].Parent then charPartsCache[i].CanCollide = true end end end
        end

        local bg = target:FindFirstChild("VuKhoa_Gyro")
        local bav = target:FindFirstChild("VuKhoa_Spin")
        
        if spinBotActive then
            if bg then bg:Destroy() end 
            bav = bav or Instance.new("BodyAngularVelocity")
            bav.Name = "VuKhoa_Spin"
            bav.MaxTorque = Vector3.new(0, math.huge, 0)
            bav.AngularVelocity = Vector3.new(0, currentSpinSpeed * 1.25, 0) 
            bav.Parent = target
        else
            if bav then bav:Destroy() end 
            if isControllerMoving or moonwalkActive then
                bg = bg or Instance.new("BodyGyro")
                bg.Name = "VuKhoa_Gyro"; bg.P = 100000; bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge); bg.Parent = target
                
                if moonwalkActive then
                    local activeDir = isControllerMoving and mv or joystickDir
                    local flatMv = Vector3.new(activeDir.X, 0, activeDir.Z)
                    if flatMv.Magnitude > 0.001 then bg.CFrame = CFrame.lookAt(target.Position, target.Position - flatMv) end
                else
                    if moveModeFace then
                        if lastMv.X ~= 0 or lastMv.Z ~= 0 then 
                            local flatMv = Vector3.new(lastMv.X, 0, lastMv.Z)
                            if flatMv.Magnitude > 0.001 then bg.CFrame = CFrame.lookAt(target.Position, target.Position + flatMv) end
                        end
