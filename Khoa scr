local mapCache = {}
local deleteWallLoop = nil

local function DoDeleteWall(v)
    if v:IsA("BasePart") and not v:IsA("Terrain") then
        local isChar = false; local p = v.Parent
        while p and p ~= workspace do if p:FindFirstChild("Humanoid") then isChar = true; break end; p = p.Parent end
        
        if not isChar then
            local n = v.Name:lower()
            if n:match("floor") or n:match("base") or n:match("ground") or n:match("spawn") or n:match("terrain") then return end
            
            local sx, sy, sz = v.Size.X, v.Size.Y, v.Size.Z
            local isFlat = sy < 10 and (sx > 20 and sz > 20)
            local isWallShape = sy >= 7 and (sx <= 15 or sz <= 15)
            
            if not isFlat and isWallShape and v.CanCollide then 
                if not mapCache[v] then mapCache[v] = {CanCollide = v.CanCollide, Transparency = v.Transparency} end
                v.CanCollide = false
                v.Transparency = 0.85 
            end
        end
    end
end

CreateBtn(ScrollHidden, "Xóa Tường (Test)", function(s)
    if s then
        for _, v in pairs(workspace:GetDescendants()) do DoDeleteWall(v) end
        deleteWallLoop = workspace.DescendantAdded:Connect(function(v) task.wait(0.1); DoDeleteWall(v) end)
    else
        if deleteWallLoop then deleteWallLoop:Disconnect(); deleteWallLoop = nil end
        for v, props in pairs(mapCache) do pcall(function() if v and v.Parent then v.CanCollide = props.CanCollide; v.Transparency = props.Transparency end end) end
        mapCache = {}
    end
end)

