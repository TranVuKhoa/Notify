local function createBtn(txt, callback)
    local btn = Instance.new("TextButton", Content)
    btn.Size = UDim2.new(0.9, 0, 0, 32); btn.Position = UDim2.new(0.05, 0, 0, 0)
    btn.BackgroundTransparency = 1; btn.Text = ""
    local box = Instance.new("Frame", btn)
    box.Size = UDim2.new(0, 18, 0, 18); box.Position = UDim2.new(0, 5, 0.5, -9); box.BackgroundColor3 = Color3.fromRGB(40,40,40)
    local lbl = Instance.new("TextLabel", btn)
    lbl.Text = txt; lbl.Size = UDim2.new(1, -30, 1, 0); lbl.Position = UDim2.new(0, 30, 0, 0); lbl.BackgroundTransparency = 1; lbl.TextColor3 = Color3.new(1,1,1); lbl.TextXAlignment = "Left"; lbl.Font = "Gotham"; lbl.TextSize = 13
    
    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        box.BackgroundColor3 = active and Color3.fromRGB(114, 137, 218) or Color3.fromRGB(40,40,40)
        callback(active)
        CreateNotify("VKhoa Sync", txt.." : "..(active and "BẬT" or "TẮT"), 2)
    end)
end

