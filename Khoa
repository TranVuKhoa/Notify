-- 3. LOGIC KÉO THẢ (FIXED)
local dragToggle, dragStart, startPos
local function updateInput(input)
    local delta = input.Position - dragStart
    MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

TitleBar.InputBegan:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
        dragToggle = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragToggle = false end
        end)
    end
end)

uis.InputChanged:Connect(function(input)
    if dragToggle and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        updateInput(input)
    end
end)

-- 4. HEARTBEAT (DI CHUYỂN & CHỨC NĂNG)
runService.Heartbeat:Connect(function(dt)
    local char = lp.Character; if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local root = char.HumanoidRootPart
    
    -- Xray ESP
    if xrayActive then
        for _, p in pairs(game.Players:GetPlayers()) do
            if p ~= lp and p.Character then
                local h = p.Character:FindFirstChild("TrVuKhoaa_ESP") or Instance.new("Highlight", p.Character)
                h.Name = "TrVuKhoaa_ESP"; h.FillColor = Color3.new(0, 0.5, 1)
            end
        end
    else
        for _, p in pairs(game.Players:GetPlayers()) do if p.Character and p.Character:FindFirstChild("TrVuKhoaa_ESP") then p.Character.TrVuKhoaa_ESP:Destroy() end end
    end

    -- Di chuyển Noclip mượt mà
    local target = (ghostActive and ghostModel) and ghostModel:FindFirstChild("HumanoidRootPart") or root
    if localMoveDir.Magnitude > 0 then
        for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end
        local cam = workspace.CurrentCamera
        local lookVec = cam.CFrame.LookVector * -localMoveDir.Z
        local rightVec = cam.CFrame.RightVector * localMoveDir.X
        local upVec = Vector3.new(0,1,0) * localMoveDir.Y
        local finalVec = (lookVec + rightVec + upVec)
        if finalVec.Magnitude > 0 then
            target.CFrame = target.CFrame + (finalVec.Unit * (currentSpeed * 50 * dt))
        end
    end
    
    if ghimActive and lockedPos and not ghostActive then root.CFrame = lockedPos; root.Velocity = Vector3.zero end
    if ghostActive then root.CFrame = lockedPos or root.CFrame; root.Velocity = Vector3.zero end
end)

