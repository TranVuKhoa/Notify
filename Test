local function createBtn(parent, txt, isGrid, callback)
    local btn = Instance.new("TextButton", parent)
    if not isGrid then btn.Size = UDim2.new(1, 0, 0, 35) end
    btn.BackgroundTransparency = 1; btn.Text = ""
    local box = Instance.new("Frame", btn)
    box.Size = UDim2.new(0, 24, 0, 24); box.Position = UDim2.new(0, 8, 0.5, -12); box.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 6)
    local lbl = Instance.new("TextLabel", btn)
    lbl.Size = UDim2.new(1, -45, 1, 0); lbl.Position = UDim2.new(0, 45, 0, 0); lbl.BackgroundTransparency = 1; lbl.Text = txt; lbl.Font = Enum.Font.Gotham; lbl.TextColor3 = Color3.new(0.9, 0.9, 0.9); lbl.TextSize = 16; lbl.TextXAlignment = "Left"
    
    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        box.BackgroundColor3 = active and Color3.fromRGB(114, 137, 218) or Color3.fromRGB(40, 40, 40)
        callback(active)
        local status = active and "BẬT" or "TẮT"
        CreateNotify("Tính năng", txt .. " đang: " .. status, 2)
    end)
end

