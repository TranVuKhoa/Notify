        local data = {}
        data.Box = Instance.new("Frame", ESPLayer); data.Box.BackgroundTransparency = 1; data.Box.Visible = false
        local stroke = Instance.new("UIStroke", data.Box); stroke.Color = IOS_BLUE; stroke.Thickness = 1.5; stroke.Transparency = 0.2
        data.Line = Instance.new("Frame", ESPLayer); data.Line.BackgroundColor3 = IOS_BLUE; data.Line.BorderSizePixel = 0; data.Line.AnchorPoint = Vector2.new(0.5, 0.5); data.Line.Visible = false; data.Line.BackgroundTransparency = 0.2
        espCache[player] = data
    end
    return espCache[player]
end

-- MAIN HEARTBEAT & RENDER LOOP
local lastTick, frameCount = os.clock(), 0
runService.RenderStepped:Connect(function(dt)
    if fpsActive then frameCount = frameCount + 1; local currentTick = os.clock(); if currentTick - lastTick >= 1 then FpsLabel.Text = "FPS: " .. frameCount; frameCount = 0; lastTick = currentTick end end
    
    local char = lp.Character; if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local root = char.HumanoidRootPart
    local target = (ghostActive and ghostModel) and ghostModel:FindFirstChild("HumanoidRootPart") or root
    
    -- TÍCH HỢP FLY X-RAY VÀO CÁC NÚT DI CHUYỂN
    if localMoveDir.Magnitude > 0 then
        local bv = target:FindFirstChild("VuKhoa_Fly") or Instance.new("BodyVelocity")
        bv.Name = "VuKhoa_Fly"; bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        
        local moveVec = (target.CFrame.LookVector * -localMoveDir.Z) + (target.CFrame.RightVector * localMoveDir.X) + (Vector3.new(0,1,0) * localMoveDir.Y)
        if moveVec.Magnitude > 0 then bv.Velocity = moveVec.Unit * (currentSpeed * 50) else bv.Velocity = Vector3.zero end
        bv.Parent = target
        
        if char:FindFirstChild("Humanoid") then char.Humanoid:ChangeState(Enum.HumanoidStateType.Freefall) end
        for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end
    else
        local bv = target:FindFirstChild("VuKhoa_Fly")
        if bv then 
            bv:Destroy() 
            if not ghostActive then
                for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = true end end
            end
        end
    end
    
    if (ghostActive or ghimActive) and lockedPos then root.CFrame = lockedPos; root.Velocity = Vector3.zero end
    if spinBotActive then root.CFrame = root.CFrame * CFrame.Angles(0, math.rad(50), 0) end

    -- Xử lý ESP
    local playerCount = 0
    local bCenter = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y)
    
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= lp then
            if p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                playerCount = playerCount + 1
                local eChar = p.Character; local eRoot = eChar.HumanoidRootPart
                
                if xrayActive then
                    local h = eChar:FindFirstChild("TrVuKhoaa_ESP") or Instance.new("Highlight", eChar); h.FillColor = IOS_BLUE; h.Name = "TrVuKhoaa_ESP"
                else
                    local h = eChar:FindFirstChild("TrVuKhoaa_ESP"); if h then h:Destroy() end
                end
                
                local espData = getESP(p)
                local headPos, headVis = cam:WorldToViewportPoint(eRoot.Position + Vector3.new(0, 3.5, 0))
                local feetPos, feetVis = cam:WorldToViewportPoint(eRoot.Position - Vector3.new(0, 3.5, 0))
                
                if headVis or feetVis then
                    if espBoxActive then
                        local height = math.abs(headPos.Y - feetPos.Y); local width = height * 0.6
                        espData.Box.Size = UDim2.new(0, width, 0, height); espData.Box.Position = UDim2.new(0, headPos.X - width/2, 0, headPos.Y); espData.Box.Visible = true
                    else espData.Box.Visible = false end
                    
                    if espLineActive then
                        local pPos = Vector2.new(feetPos.X, feetPos.Y); local dist = (bCenter - pPos).Magnitude
                        espData.Line.Size = UDim2.new(0, dist, 0, 1.5); espData.Line.Position = UDim2.new(0, (bCenter.X + pPos.X)/2, 0, (bCenter.Y + pPos.Y)/2)
                        espData.Line.Rotation = math.deg(math.atan2(pPos.Y - bCenter.Y, pPos.X - bCenter.X)); espData.Line.Visible = true
                    else espData.Line.Visible = false end
                else
                    espData.Box.Visible = false; espData.Line.Visible = false
                end
            else
                if espCache[p] then espCache[p].Box.Visible = false; espCache[p].Line.Visible = false end
            end
        end
    end
    for p, data in pairs(espCache) do if not p or not p.Parent then data.Box:Destroy(); data.Line:Destroy(); espCache[p] = nil end end
    if espCountActive then CountLabel.Text = "Địch: " .. playerCount end
end)
