-- [[ HỆ THỐNG FLING CHỐNG VĂNG NGƯỢC (ANCHOR RETURN) ]]
local function FlingPlayer(targetPlayer)
    if isFlinging or not lp.Character or not lp.Character:FindFirstChild("HumanoidRootPart") then return end
    if not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    
    isFlinging = true
    local char = lp.Character
    local root = char.HumanoidRootPart
    local targetRoot = targetPlayer.Character.HumanoidRootPart
    local hum = char:FindFirstChild("Humanoid")
    local savedCFrame = root.CFrame
    
    SendNotify("Fling", "Đang bón hành: " .. targetPlayer.Name, 1.5)
    
    local oldState = hum and hum:GetState() or Enum.HumanoidStateType.Running
    if hum then hum:ChangeState(Enum.HumanoidStateType.Physics) end

    -- Dọn dẹp body movers
    for _, v in pairs(root:GetChildren()) do
        if v:IsA("BodyVelocity") or v:IsA("BodyGyro") or v:IsA("BodyAngularVelocity") or v:IsA("BodyThrust") then v:Destroy() end
    end
    
    -- Buff Tạ: Tăng trọng lượng, tắt CanCollide các bộ phận dư thừa
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("BasePart") then 
            v.CustomPhysicalProperties = PhysicalProperties.new(100, 0.3, 0.5) 
            v.CanCollide = false 
        end
    end
    root.CanCollide = true 
    
    local bav = Instance.new("BodyAngularVelocity")
    bav.Name = "VuKhoa_FlingForce"
    bav.AngularVelocity = Vector3.new(0, 9e5, 0) -- Xoay lốc xoáy quanh trục Y
    bav.MaxTorque = Vector3.new(0, math.huge, 0)
    bav.P = math.huge
    bav.Parent = root
    
    local startTime = os.clock()
    
    -- Dùng vòng lặp đồng bộ có Cảm biến vận tốc ngắt thông minh
    while os.clock() - startTime < 1.5 do
        runService.Heartbeat:Wait()
        
        -- Check an toàn: Đối thủ rời game hoặc chết
        if not targetPlayer or not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then 
            break 
        end
        
        targetRoot = targetPlayer.Character.HumanoidRootPart
        
        -- [ CẢM BIẾN ]: Tránh bị bay theo! Nếu đối thủ bay tốc độ cao hoặc văng khỏi map thì ngắt ngay.
        if targetRoot.Velocity.Magnitude > 250 or targetRoot.Position.Y < -50 then
            break
        end
        
        -- Cọ xát vật lý
        root.Velocity = Vector3.zero 
        root.RotVelocity = Vector3.new(50000, 50000, 50000)
        root.CFrame = targetRoot.CFrame * CFrame.new(math.random(-1, 1), math.random(-0.5, 0.5), math.random(-1, 1))
    end
    
    -- Kết thúc hủy diệt, dọn dẹp
    if bav then bav:Destroy() end
    if hum then hum:ChangeState(oldState) end
    
    -- Khôi phục trọng lượng
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("BasePart") then 
            v.CustomPhysicalProperties = PhysicalProperties.new(0.7, 0.3, 0.5) 
        end
    end
    
    -- [ FIX MẠNH ]: KHÓA BĂNG NHÂN VẬT ĐỂ TRIỆT TIÊU LỰC PHẢN HỒI
    if root then
        root.Anchored = true
        root.Velocity = Vector3.zero
        root.RotVelocity = Vector3.zero
        root.CFrame = savedCFrame
    end
    
    task.wait(0.1) -- Chờ game nhận diện bạn đứng im
    
    if root then
        root.CFrame = savedCFrame
        root.Anchored = false -- Mở băng
    end
    
    SendNotify("Fling", "Xong việc, đứng vững!", 1.5)
    isFlinging = false
end

-- [[ TỐI ƯU HÓA: TÌM MỤC TIÊU SILENT AIM ]]
local function getNearestTarget()
    local nearestDist = math.huge
    local potentialTargets = {}
    local mPos = uis:GetMouseLocation()
    local origin = cam.CFrame.Position
    
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= lp and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
            local head = p.Character:FindFirstChild("Head")
            local body = p.Character:FindFirstChild("HumanoidRootPart") or p.Character:FindFirstChild("UpperTorso")
            if head and body then
                local screenPos, onScreen = cam:WorldToViewportPoint(head.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - mPos).Magnitude
                    table.insert(potentialTargets, {player = p, distance = dist, head = head, body = body})
                end
            end
        end
    end
    table.sort(potentialTargets, function(a, b) return a.distance < b.distance end)
    
    for _, targetData in ipairs(potentialTargets) do
        local params = RaycastParams.new()
        local ignoreList = {lp.Character, targetData.player.Character}
        if ghostModel then table.insert(ignoreList, ghostModel) end
        params.FilterDescendantsInstances = ignoreList
        params.FilterType = Enum.RaycastFilterType.Exclude
        params.IgnoreWater = true
        
        local result = workspace:Raycast(origin, targetData.head.Position - origin, params)
        if not result then
            local rand = math.random(1, 100)
            if rand <= silentAimHeadshotRate then return targetData.head else return targetData.body end
        end
    end
    return nil
end

