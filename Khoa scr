local function SwitchTab(tabName)
    local targetData = tabFrames[tabName]
    local newIndex = targetData.index
    local tweenTime = 0.25
    
    if newIndex ~= currentTabIndex then
        for name, data in pairs(tabFrames) do
            local frm = data.frame
            if name == tabName then
                frm.Position = UDim2.new(newIndex > currentTabIndex and 1 or -1, 0, 0, 80)
                frm.Visible = true
                frm:TweenPosition(UDim2.new(0, 0, 0, 80), "Out", "Quart", tweenTime, true)
            elseif data.index == currentTabIndex then
                local exitPos = UDim2.new(newIndex > currentTabIndex and -1 or 1, 0, 0, 80)
                frm:TweenPosition(exitPos, "Out", "Quart", tweenTime, true)
                task.delay(tweenTime, function() if currentTabIndex == newIndex and frm.Position == exitPos then frm.Visible = false end end)
            else
                frm.Visible = false
            end
        end
        currentTabIndex = newIndex
    else
        tabFrames[tabName].frame.Position = UDim2.new(0, 0, 0, 80)
        tabFrames[tabName].frame.Visible = true
    end

    TabMainBtn.TextColor3 = (tabName == "Main") and IOS_BLUE or Color3.fromRGB(150, 150, 160)
    TabPage2Btn.TextColor3 = (tabName == "Page2") and IOS_BLUE or Color3.fromRGB(150, 150, 160)
