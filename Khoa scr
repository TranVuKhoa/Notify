local function getNearestTarget()
    local nearestDist = math.huge
    local potentialTargets = {}
    local mPos = uis:GetMouseLocation()
    local origin = cam.CFrame.Position
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= lp and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
            local head = p.Character:FindFirstChild("Head")
            local body = p.Character:FindFirstChild("HumanoidRootPart") or p.Character:FindFirstChild("UpperTorso")
            if head and body then
                local screenPos, onScreen = cam:WorldToViewportPoint(head.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - mPos).Magnitude
                    table.insert(potentialTargets, {player = p, distance = dist, head = head, body = body})
                end
            end
        end
    end
    table.sort(potentialTargets, function(a, b) return a.distance < b.distance end)
    for _, targetData in ipairs(potentialTargets) do
        local params = RaycastParams.new()
        local ignoreList = {lp.Character, targetData.player.Character}
        if ghostModel then table.insert(ignoreList, ghostModel) end
        params.FilterDescendantsInstances = ignoreList; params.FilterType = Enum.RaycastFilterType.Exclude; params.IgnoreWater = true
        local result = workspace:Raycast(origin, targetData.head.Position - origin, params)
        if not result then
            local rand = math.random(1, 100)
            if rand <= silentAimHeadshotRate then return targetData.head else return targetData.body end
        end
    end
    return nil
end

