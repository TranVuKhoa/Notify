--- [Chú thích: Logic chuyển tab và cập nhật viền tab]
local function SwitchTab(tabName)
    local targetData = tabFrames[tabName]; local newIndex = targetData.index; local tweenTime = 0.25
    if newIndex ~= currentTabIndex then
        for name, data in pairs(tabFrames) do
            local frm = data.frame
            if name == tabName then frm.Position = UDim2.new(newIndex > currentTabIndex and 1 or -1, 0, 0, 80); frm.Visible = true; frm:TweenPosition(UDim2.new(0, 0, 0, 80), "Out", "Quart", tweenTime, true)
            elseif data.index == currentTabIndex then local exitPos = UDim2.new(newIndex > currentTabIndex and -1 or 1, 0, 0, 80); frm:TweenPosition(exitPos, "Out", "Quart", tweenTime, true); task.delay(tweenTime, function() if currentTabIndex == newIndex and frm.Position == exitPos then frm.Visible = false end end)
            else frm.Visible = false end
        end
        currentTabIndex = newIndex
    else tabFrames[tabName].frame.Position = UDim2.new(0, 0, 0, 80); tabFrames[tabName].frame.Visible = true end

    TabMainBtn.TextColor3 = (tabName == "Main") and IOS_BLUE or Color3.fromRGB(150, 150, 160)
    TabPage2Btn.TextColor3 = (tabName == "Page2") and IOS_BLUE or Color3.fromRGB(150, 150, 160)
    TabESPBtn.TextColor3 = (tabName == "ESP") and IOS_BLUE or Color3.fromRGB(150, 150, 160)
    TabHiddenBtn.TextColor3 = (tabName == "Hidden") and IOS_BLUE or Color3.fromRGB(150, 150, 160)
    TabInfoBtn.TextColor3 = (tabName == "Info") and IOS_BLUE or Color3.fromRGB(150, 150, 160)
    
    local is5Tabs = TabHiddenBtn.Visible
    TabIndicator.Size = UDim2.new(is5Tabs and 0.16 or 0.20, 0, 0, 2)
    if tabName == "Main" then TabIndicator:TweenPosition(UDim2.new(is5Tabs and 0.02 or 0.025, 0, 1, -2), "Out", "Quart", tweenTime, true)
    elseif tabName == "Page2" then TabIndicator:TweenPosition(UDim2.new(is5Tabs and 0.22 or 0.275, 0, 1, -2), "Out", "Quart", tweenTime, true)
    elseif tabName == "ESP" then TabIndicator:TweenPosition(UDim2.new(is5Tabs and 0.42 or 0.525, 0, 1, -2), "Out", "Quart", tweenTime, true)
    elseif tabName == "Hidden" then TabIndicator:TweenPosition(UDim2.new(0.62, 0, 1, -2), "Out", "Quart", tweenTime, true)
    elseif tabName == "Info" then TabIndicator:TweenPosition(UDim2.new(is5Tabs and 0.82 or 0.775, 0, 1, -2), "Out", "Quart", tweenTime, true) end
end

