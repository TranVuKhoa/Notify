local function IsVis(part, cam)
    if not Cfg.WallCheck then return true end
    local ray = RaycastParams.new(); ray.FilterDescendantsInstances = {player.Character, cam}; ray.FilterType = Enum.RaycastFilterType.Exclude
    local c = Workspace:Raycast(cam.CFrame.Position, part.Position - cam.CFrame.Position, ray)
    return not c or c.Instance:IsDescendantOf(part.Parent)
end

local function IsKillable(p, cam)
    if not p or not p.Character then return false end
    local hum = p.Character:FindFirstChild("Humanoid"); local part = p.Character:FindFirstChild(Cfg.Part)
    if not hum or hum.Health <= 0 or not part then return false end
    if p.Character:FindFirstChildOfClass("ForceField") then return false end
    if Cfg.TeamCheck and p.Team == player.Team then return false end
    if not IsVis(part, cam) then return false end
    return true
end

local function GetTargetInFOV()
    local target, shortest = nil, Cfg.FOVSize / 2
    local cam = Workspace.CurrentCamera; if not cam then return nil end
    local myChar = player.Character; local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and IsKillable(p, cam) then
            local part = p.Character:FindFirstChild(Cfg.Part)
            if part then
                local pos, vis = cam:WorldToViewportPoint(part.Position)
                if vis or Cfg.FOV360 then
                    local mag = (Vector2.new(pos.X, pos.Y) - Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)).Magnitude
                    if Cfg.FOV360 and myHRP then 
                        mag = (myHRP.Position - part.Position).Magnitude 
                    end
                    if mag < shortest then shortest = mag; target = p end
                end
            end
        end
    end
    return target
end

local lastAutoFire = 0
RunService.Heartbeat:Connect(function()
    if not Cfg.Master then return end
    local myChar = player.Character; if not myChar then return end

    pcall(function()
        local h = myChar:FindFirstChild("Humanoid"); local hrp = myChar:FindFirstChild("HumanoidRootPart")
        if h and hrp then
            local myPos = hrp.Position
            
            if Cfg.UpPlayer then
                h.CameraOffset = Vector3.new(0, Cfg.UpHeight, 0)
            else
                h.CameraOffset = Vector3.new(0, 0, 0)
            end
            
            local joint = hrp:FindFirstChild("RootJoint")
            if not joint and myChar:FindFirstChild("LowerTorso") then
                joint = myChar.LowerTorso:FindFirstChild("Root")
            end
            
            if joint then
                if not OrigTrans["RootJointC0"] then OrigTrans["RootJointC0"] = joint.C0 end
                local newC0 = OrigTrans["RootJointC0"]

                if Cfg.AntiAim then
                    newC0 = newC0 * CFrame.Angles(math.rad(math.random(-50,50)), math.rad(math.random(-180,180)), math.rad(math.random(-50,50)))
                end
                
                joint.C0 = newC0
            end

            if Cfg.ThirdPerson then 
                player.CameraMode = Enum.CameraMode.Classic; player.CameraMinZoomDistance = 15; player.CameraMaxZoomDistance = 15 
            else 
                player.CameraMinZoomDistance = 0.5; player.CameraMaxZoomDistance = 400 
            end

            if Cfg.HideSelf then for _, v in pairs(myChar:GetDescendants()) do if (v:IsA("BasePart") or v:IsA("Decal")) and v.Name ~= "HumanoidRootPart" then if not OrigTrans[v] then OrigTrans[v] = v.Transparency end; v.Transparency = 1 end end end
            
            if Cfg.UpPlayer then
                local targetY = myPos.Y + Cfg.UpHeight
                for _, p in ipairs(Players:GetPlayers()) do
                    if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        if not (Cfg.AimMagnet and (isShooting or Cfg.AutoFire) and p == sharedTarget) then
                            local eHRP = p.Character.HumanoidRootPart
                            eHRP.CFrame = CFrame.new(eHRP.Position.X, targetY, eHRP.Position.Z)
