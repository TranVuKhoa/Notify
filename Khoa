-- 1. HỆ THỐNG THÔNG BÁO (NOTIFY - MÀU ĐEN XANH TRẮNG)
local NotifyGui = Instance.new("ScreenGui", coreGui)
NotifyGui.Name = "VuKhoa_Notify_System"

local function SendNotify(title, text, duration)
    local NotifyFrame = Instance.new("Frame", NotifyGui)
    NotifyFrame.Size = UDim2.new(0, 230, 0, 65)
    NotifyFrame.Position = UDim2.new(1, -240, 1, -100) -- Góc dưới phải
    NotifyFrame.BackgroundColor3 = Color3.fromRGB(10, 10, 10) -- Nền đen đậm
    NotifyFrame.BorderSizePixel = 0
    
    local Corner = Instance.new("UICorner", NotifyFrame)
    Corner.CornerRadius = UDim.new(0, 8)
    
    local Stroke = Instance.new("UIStroke", NotifyFrame)
    Stroke.Color = Color3.fromRGB(0, 120, 255) -- Viền xanh Neon
    Stroke.Thickness = 1.8

    local TitleLbl = Instance.new("TextLabel", NotifyFrame)
    TitleLbl.Text = "  " .. title
    TitleLbl.Size = UDim2.new(1, 0, 0, 25)
    TitleLbl.BackgroundTransparency = 1
    TitleLbl.TextColor3 = Color3.fromRGB(0, 150, 255) -- Tiêu đề màu xanh
    TitleLbl.Font = Enum.Font.GothamBold
    TitleLbl.TextSize = 16
    TitleLbl.TextXAlignment = "Left"

    local ContentLbl = Instance.new("TextLabel", NotifyFrame)
    ContentLbl.Text = "  " .. text
    ContentLbl.Size = UDim2.new(1, -10, 1, -25)
    ContentLbl.Position = UDim2.new(0, 0, 0, 25)
    ContentLbl.BackgroundTransparency = 1
    ContentLbl.TextColor3 = Color3.fromRGB(255, 255, 255) -- Nội dung màu trắng
    ContentLbl.Font = Enum.Font.Gotham
    ContentLbl.TextSize = 14
    ContentLbl.TextWrapped = true
    ContentLbl.TextXAlignment = "Left"
    ContentLbl.TextYAlignment = "Top"

    -- Hiệu ứng trượt vào (Slide in)
    NotifyFrame.Position = UDim2.new(1, 0, 1, -100)
    NotifyFrame:TweenPosition(UDim2.new(1, -240, 1, -100), "Out", "Quad", 0.3, true)

    task.delay(duration or 3, function()
        for i = 0, 1, 0.1 do
            if NotifyFrame then
                NotifyFrame.BackgroundTransparency = i
                TitleLbl.TextTransparency = i
                ContentLbl.TextTransparency = i
                Stroke.Transparency = i
            end
            task.wait(0.05)
        end
        if NotifyFrame then NotifyFrame:Destroy() end
    end)
end

