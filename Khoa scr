--- [Chú thích: Hàm sinh Button (Nút gạt bật tắt)]
local function CreateBtn(parent, textData, callback, defaultActive)
    local isTranslating = type(textData) == "table"
    local viText = isTranslating and textData[1] or textData
    local enText = isTranslating and textData[2] or textData

    local Btn = Instance.new("TextButton", parent); Btn.Size = UDim2.new(0.92, 0, 0, 34); Btn.BackgroundColor3 = Color3.fromRGB(255, 255, 255); Btn.BackgroundTransparency = 0.92; Btn.Text = "" 
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 10)
    local Square = Instance.new("Frame", Btn); Square.Size = UDim2.new(0, 16, 0, 16); Square.Position = UDim2.new(0, 10, 0.5, -8); Square.BorderSizePixel = 0;
    Instance.new("UICorner", Square).CornerRadius = UDim.new(1, 0)
    local Label = Instance.new("TextLabel", Btn); Label.Size = UDim2.new(1, -40, 1, 0); Label.Position = UDim2.new(0, 35, 0, 0); Label.BackgroundTransparency = 1; Label.Font = Enum.Font.Gotham; Label.TextColor3 = Color3.fromRGB(240, 240, 245); Label.TextSize = 12; Label.TextXAlignment = "Left"
    RegLang(Label, "Text", viText, enText)

    Btn:SetAttribute("IsActive", defaultActive or false)
    local function UpdateState()
        local isActive = Btn:GetAttribute("IsActive")
        Square.BackgroundColor3 = isActive and IOS_BLUE or Color3.fromRGB(80, 80, 85)
        Square.BackgroundTransparency = isActive and 0.1 or 0.6
    end
    UpdateState()
    
    Btn.MouseButton1Click:Connect(function() 
        local newState = not Btn:GetAttribute("IsActive")
        Btn:SetAttribute("IsActive", newState)
        callback(newState)
        if viText ~= "🌐 Tiếng Việt / English" and viText ~= "Giật Lag Ảo (Fake Lag)" and viText ~= "Bảng Nhân Tốc Độ & Nhảy" and viText ~= "Bảng Chạy Code Remote" then 
            SendNotify(L("Cài Đặt", "Settings"), L(viText, enText) .. (newState and L(" BẬT", " ON") or L(" TẮT", " OFF")), 1.2) 
        end
    end)
    Btn:GetAttributeChangedSignal("IsActive"):Connect(UpdateState)
    return Btn
