local function createBtn(parent, txt, isGrid, callback)
    local btn = Instance.new("TextButton", parent)
    if not isGrid then btn.Size = UDim2.new(1, 0, 0, 32) end
    btn.BackgroundTransparency = 1; btn.Text = ""
    
    local box = Instance.new("Frame", btn)
    box.Size = UDim2.new(0, 24, 0, 24)
    box.Position = UDim2.new(0, 0, 0.5, -12)
    box.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    box.BorderSizePixel = 0
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 4)
    
    local lbl = Instance.new("TextLabel", btn)
    lbl.Size = UDim2.new(1, -35, 1, 0); lbl.Position = UDim2.new(0, 35, 0, 0)
    lbl.BackgroundTransparency = 1; lbl.Text = txt; lbl.Font = Enum.Font.Antique
    lbl.TextColor3 = Color3.new(0.9, 0.9, 0.9); lbl.TextSize = 18; lbl.TextXAlignment = Enum.TextXAlignment.Left
    
    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        box.BackgroundColor3 = active and Color3.fromRGB(75, 115, 255) or Color3.fromRGB(30, 30, 30)
        callback(active)
        SendNotify("Chức năng", txt .. (active and " : Bật" or " : Tắt"), 2)
    end)
end

