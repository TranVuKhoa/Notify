local function getNearestTarget()
    local nearestDist = math.huge
    local nearestTarget = nil
    local mPos = uis:GetMouseLocation()
    local origin = cam.CFrame.Position
    
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= lp and p.Character and p.Character:FindFirstChild("Head") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
            local head = p.Character.Head
            local screenPos, onScreen = cam:WorldToViewportPoint(head.Position)
            
            if onScreen then
                local dist = (Vector2.new(screenPos.X, screenPos.Y) - mPos).Magnitude
                if dist < nearestDist then
                    -- WALL CHECK: Phóng tia kiểm tra vật cản
                    local params = RaycastParams.new()
                    local ignoreList = {lp.Character, p.Character}
                    if ghostModel then table.insert(ignoreList, ghostModel) end
                    params.FilterDescendantsInstances = ignoreList
                    params.FilterType = Enum.RaycastFilterType.Exclude
                    params.IgnoreWater = true
                    
                    local result = workspace:Raycast(origin, head.Position - origin, params)
                    
                    -- Nếu result == nil tức là không va trúng bức tường nào -> Mục tiêu nhìn thấy được
                    if not result then
                        nearestDist = dist
                        nearestTarget = head
                    end
                end
            end
        end
    end
    return nearestTarget
end

-- Bypass Anti-Cheat & God Mode Hook & SMART Silent Aim Hook
pcall(function()
    local mt = getrawmetatable(game)
    local oldIndex = mt.__index
    local oldNamecall = mt.__namecall
    local oldNewindex = mt.__newindex
    setreadonly(mt, false)

    mt.__index = newcclosure(function(self, key)
        if not checkcaller() then
            if key == "WalkSpeed" and self:IsA("Humanoid") then return 16 end
            if key == "JumpPower" and self:IsA("Humanoid") then return 50 end
        end
        return oldIndex(self, key)
    end)

    mt.__newindex = newcclosure(function(self, key, value)
        if not checkcaller() and (godMode1Active or godMode2Active or godMode3Active) and self:IsA("Humanoid") then
            if key == "Health" or key == "MaxHealth" then return end
        end
        return oldNewindex(self, key, value)
    end)

    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}

        if not checkcaller() then
            if (method == "Kick" or method == "kick") and self == lp then return nil end
            
            -- Chặn Damage cho God Mode
            if (godMode1Active or godMode2Active or godMode3Active) then
                if method == "TakeDamage" and self:IsA("Humanoid") then return nil end
                if method == "BreakJoints" and self == lp.Character then return nil end
            end

            -- SMART SILENT AIM: Bẻ đạn trúng đích
            if silentAimActive and currentSilentAimTarget then
                if method == "Raycast" and typeof(args[1]) == "Vector3" and typeof(args[2]) == "Vector3" then
                    local dirMag = args[2].Magnitude
                    if dirMag > 150 then 
                        args[2] = (currentSilentAimTarget.Position - args[1]).Unit * dirMag
                        return oldNamecall(self, unpack(args))
                    end
                elseif method == "FindPartOnRayWithIgnoreList" or method == "FindPartOnRayWithWhitelist" or method == "FindPartOnRay" then
                    if typeof(args[1]) == "Ray" then
                        local ray = args[1]
                        local dirMag = ray.Direction.Magnitude
                        if dirMag > 150 then
                            local origin = ray.Origin
                            local dir = (currentSilentAimTarget.Position - origin).Unit * dirMag
                            args[1] = Ray.new(origin, dir)
                            return oldNamecall(self, unpack(args))
                        end
                    end
                end
            end
        end
        return oldNamecall(self, unpack(args))
    end)
    setreadonly(mt, true)
end)

