                    bav.Parent = hrp
                end
                bav.AngularVelocity = Vector3.new(0, Cfg.SpinSpeed / 10, 0)
            else
                h.AutoRotate = true
                local bav = hrp:FindFirstChild("SpinBotBav")
                if bav then bav:Destroy() end
            end
        end
    end)

    pcall(function()
        local cam = Workspace.CurrentCamera
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character then
                local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    if Cfg.Hitbox and IsKillable(p, cam) then
                        if not OrigHitboxData[hrp] then OrigHitboxData[hrp] = {Size = hrp.Size, Trans = hrp.Transparency, Collide = hrp.CanCollide, Massless = hrp.Massless} end
                        local actualSize = math.clamp(Cfg.HitboxSize, 5, 50)
                        hrp.Size = Vector3.new(actualSize, actualSize, actualSize)
                        hrp.Transparency = 1
                        hrp.CanCollide = false
                        hrp.Massless = true 
                    else
                        if OrigHitboxData[hrp] then 
                            hrp.Size = OrigHitboxData[hrp].Size
                            hrp.Transparency = OrigHitboxData[hrp].Trans
                            hrp.CanCollide = OrigHitboxData[hrp].Collide
                            hrp.Massless = OrigHitboxData[hrp].Massless
                            OrigHitboxData[hrp] = nil 
                        end
                    end
                end
            end
        end
    end)

    pcall(function()
        if sharedTarget and typeof(sharedTarget) == "Instance" and sharedTarget.Character and sharedTarget.Character:FindFirstChild("HumanoidRootPart") then
            local eHRP = sharedTarget.Character.HumanoidRootPart
            if (isShooting or Cfg.AutoFire) and myChar and myChar:FindFirstChild("HumanoidRootPart") then
                if Cfg.AimMagnet then
                    local cam = Workspace.CurrentCamera
                    local lookDir = cam.CFrame.LookVector
                    local camPos = myChar.HumanoidRootPart.Position + myChar.Humanoid.CameraOffset
                    
                    local magnetPos = camPos + (lookDir * 20)
                    eHRP.CFrame = CFrame.new(magnetPos, camPos)
                    eHRP.AssemblyLinearVelocity = Vector3.new(0,0,0)
                elseif Cfg.AimKill then
                    myChar.HumanoidRootPart.CFrame = eHRP.CFrame * CFrame.new(0, 0, 4); myChar.HumanoidRootPart.Velocity = Vector3.new(0,0,0)
                end
            end
        end
    end)

    pcall(function()
        if Cfg.AutoFire and sharedTarget and typeof(sharedTarget) == "Instance" and sharedTarget.Character then
            local tool = myChar:FindFirstChildOfClass("Tool") or player.Backpack:FindFirstChildOfClass("Tool")
            if tool then
