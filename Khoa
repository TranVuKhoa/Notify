-- [[ HÀM KÉO THẢ TỐI ƯU (FIX LAG) ]]
local function makeDraggable(window, handle)
    local dragging, dragStart, startPos
    
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = window.Position
            
            -- Kết nối tạm thời để tối ưu tài nguyên
            local connection
            connection = uis.InputChanged:Connect(function(change)
                if dragging and (change.UserInputType == Enum.UserInputType.MouseMovement or change.UserInputType == Enum.UserInputType.Touch) then
                    local delta = change.Position - dragStart
                    -- Gán trực tiếp Offset để máy lag phản hồi nhanh nhất
                    window.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
                end
            end)
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                    if connection then connection:Disconnect() end
                end
            end)
        end
    end)
end
makeDraggable(MainFrame, TitleBar)

