local function SendNotify(title, text, duration)
    if not notifyEnabled then return end
    local NotifyGui = coreGui:FindFirstChild("VuKhoa_Notify_System") or Instance.new("ScreenGui", coreGui)
    NotifyGui.Name = "VuKhoa_Notify_System"
    local Frame = Instance.new("Frame", NotifyGui)
    Frame.Size = UDim2.new(0, 200, 0, 60); Frame.Position = UDim2.new(1, -210, 1, -70); Frame.BackgroundColor3 = Color3.fromRGB(15, 15, 15); Frame.BorderSizePixel = 0
    Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 8)
    local Stroke = Instance.new("UIStroke", Frame); Stroke.Color = Color3.fromRGB(88, 101, 242); Stroke.Thickness = 2
    local Tl = Instance.new("TextLabel", Frame); Tl.Text = title; Tl.Size = UDim2.new(1,0,0,25); Tl.BackgroundTransparency = 1; Tl.TextColor3 = Color3.fromRGB(88, 101, 242); Tl.Font = Enum.Font.GothamBold; Tl.TextSize = 14
    local Tx = Instance.new("TextLabel", Frame); Tx.Text = text; Tx.Size = UDim2.new(1,0,1,-25); Tx.Position = UDim2.new(0,0,0,25); Tx.BackgroundTransparency = 1; Tx.TextColor3 = Color3.new(1,1,1); Tx.Font = Enum.Font.Gotham; Tx.TextSize = 12; Tx.TextWrapped = true
    task.delay(duration or 2, function() if Frame then Frame:Destroy() end end)
end

