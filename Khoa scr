runService.Stepped:Connect(function()
    local char = lp.Character
    if char then
        if noclipActive or localMoveDir.Magnitude > 0 then
            for _, v in pairs(char:GetDescendants()) do
                if v:IsA("BasePart") then v.CanCollide = false end
            end
        end
        
        -- Anti-Fling & Anti-Void Toàn Cầu
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            local pos = hrp.Position
            if pos.Y < -200 or pos.Y > 5000 or math.abs(pos.X) > 20000 or math.abs(pos.Z) > 20000 then
                hrp.Velocity = Vector3.zero
                hrp.CFrame = CFrame.new(0, 100, 0)
                if os.clock() - lastFlingRescue > 2 then
                    lastFlingRescue = os.clock()
                    SendNotify("Anti-Fling", "Phát hiện bị văng vút! Đã kéo bạn về an toàn.", 2)
                end
            end
        end
    end

