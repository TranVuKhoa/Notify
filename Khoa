CreateBtn(ScrollMain, "Ghost Mode", function(s) 
    ghostActive = s 
    local char = lp.Character
    if s and char and char:FindFirstChild("HumanoidRootPart") then 
        lockedPos = char.HumanoidRootPart.CFrame
        char.Archivable = true
        
        -- Tạo cái xác đứng im chịu trận
        ghostModel = char:Clone()
        ghostModel.Name = "VuKhoa_Dummy"
        ghostModel.Parent = workspace
        if ghostModel:FindFirstChild("HumanoidRootPart") then
            ghostModel.HumanoidRootPart.Anchored = true
        end
        
        -- Làm mờ bản thân để tự do di chuyển (Xuất hồn)
        origProps = {}
        for _, v in pairs(char:GetDescendants()) do 
            if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then 
                origProps[v] = v.Transparency
                v.Transparency = 0.5 
                v.CanCollide = false 
            end 
        end
        SendNotify("Ghost Mode", "Đã xuất hồn! Cơ thể thật sẽ tàng hình.", 2)
    elseif not s and char then 
        -- Hủy xuất hồn, kéo cơ thể thật về lại vị trí cái xác
        if lockedPos and char:FindFirstChild("HumanoidRootPart") then
            char.HumanoidRootPart.CFrame = lockedPos
        end
        if ghostModel then ghostModel:Destroy() end
        if origProps then
            for v, trans in pairs(origProps) do
                if v and v.Parent then 
                    v.Transparency = trans
                    v.CanCollide = true 
                end
            end
            origProps = nil
        end
        SendNotify("Ghost Mode", "Đã nhập lại vào xác!", 2)
    end 
end)

