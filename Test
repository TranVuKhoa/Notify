-- HÀM TẠO NÚT (Checkbox Style)
local function CreateBtn(parent, text, callback, isGrid, defaultActive)
    local Btn = Instance.new("TextButton", parent); Btn.Size = isGrid and UDim2.new(0.45, 0, 0, 30) or UDim2.new(0.9, 0, 0, 30); Btn.BackgroundTransparency = 1; Btn.Text = ""
    local Square = Instance.new("Frame", Btn); Square.Size = UDim2.new(0, 18, 0, 18); Square.Position = UDim2.new(0, 5, 0.5, -9); Square.BackgroundColor3 = defaultActive and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(25, 25, 25); Square.BorderSizePixel = 0
    local Label = Instance.new("TextLabel", Btn); Label.Size = UDim2.new(1, -25, 1, 0); Label.Position = UDim2.new(0, 28, 0, 0); Label.BackgroundTransparency = 1; Label.Text = text; Label.Font = Enum.Font.Antique; Label.TextColor3 = Color3.new(1,1,1); Label.TextSize = 16; Label.TextXAlignment = "Left"
    local active = defaultActive or false
    Btn.MouseButton1Click:Connect(function()
        active = not active
        Square.BackgroundColor3 = active and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(25, 25, 25)
        callback(active)
        SendNotify("Hệ Thống", text .. (active and ": BẬT" or ": TẮT"), 1.5)
    end)
end

