--- [Chú thích: Thuật toán bật Fake Lag (Dồn packet và đi dạo hồn)]
function TurnOnFakeLag()
    fakeLagActive = true
    fakeLagQueue = {}
    local char = lp.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        fakeLagStartCFrame = char.HumanoidRootPart.CFrame
        char.HumanoidRootPart.Anchored = true
        char.Archivable = true
        
        ghostModel = char:Clone()
        ghostModel.Name = "VuKhoa_Ghost_FL"
        ghostModel.Parent = workspace
        for _, v in pairs(ghostModel:GetDescendants()) do
            if v:IsA("BasePart") then v.Anchored = false end
        end
        SetupGhostAnimation(ghostModel)
        MakeCharGhost(char) 
        cam.CameraSubject = ghostModel:FindFirstChild("Humanoid")
    end

    for _, v in pairs(workspace:GetDescendants()) do FreezeModel(v) end
    fakeLagDescendantConn = workspace.DescendantAdded:Connect(function(v)
        task.delay(0.1, function()
            if fakeLagActive then
                FreezeModel(v)
                if v:IsA("HumanoidRootPart") and v.Parent and v.Parent:IsA("Model") then FreezeModel(v.Parent) end
            end
        end)
    end)

    local modeName = (fakeLagMode == "Stand") and L("Đứng Yên", "Stand Still") or L("Di Chuyển", "Moving")
    FakeLagBtnFrame:FindFirstChildOfClass("TextButton").Text = "🛑"
    SendNotify("Fake Lag", L("Đã BẬT! Chế độ: ", "ENABLED! Mode: ") .. modeName, 2)
end

--- [Chú thích: Tắt Fake Lag (Xả gói tin packet và lướt vị trí tới)]
function TurnOffFakeLag()
    fakeLagActive = false
    local packetCount = #fakeLagQueue
    
    if fakeLagDescendantConn then fakeLagDescendantConn:Disconnect(); fakeLagDescendantConn = nil end
    UnfreezeAll()

    local char = lp.Character
    local endCFrame = ghostModel and ghostModel:FindFirstChild("HumanoidRootPart") and ghostModel.HumanoidRootPart.CFrame

    if ghostModel then ghostModel:Destroy(); ghostModel = nil end
    if char then
        local hum = char:FindFirstChild("Humanoid")
        if hum then cam.CameraSubject = hum end
    end

    FakeLagBtnFrame:FindFirstChildOfClass("TextButton").Text = "🌐"
    StopGhostAnimation()
    RestoreCharGhost() 
    
    if fakeLagMainBtn and fakeLagMainBtn:GetAttribute("IsActive") == true then
        fakeLagMainBtn:SetAttribute("IsActive", false)
    end

    task.spawn(function()
        if char and char:FindFirstChild("HumanoidRootPart") and fakeLagStartCFrame then
            local hrp = char.HumanoidRootPart
            local hum = char:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 then
                if fakeLagMode == "Stand" then
                    hrp.CFrame = fakeLagStartCFrame
                    hrp.Anchored = false
                    SendNotify("Fake Lag", L("TẮT! Đã quay về & xả ", "OFF! Returned & fired ") .. packetCount .. L(" gói tin", " packets"), 2.5)
                elseif fakeLagMode == "Move" and endCFrame then
                    SendNotify("Fake Lag", L("TẮT! Đang lướt vị trí...", "OFF! Gliding to target..."), 2)
                    local steps = 7
                    for i = 1, steps do
                        hrp.CFrame = fakeLagStartCFrame:Lerp(endCFrame, i / steps)
                        task.wait(0.04) 
                    end
                    hrp.CFrame = endCFrame
                    hrp.Anchored = false
                    SendNotify("Fake Lag", L("Đã xả ", "Fired ") .. packetCount .. L(" gói tin!", " packets!"), 2)
                else
                    hrp.Anchored = false
                end
            else
                hrp.Anchored = false
            end
        end

        for _, data in ipairs(fakeLagQueue) do
            pcall(function()
                if data.Method == "FireServer" then data.Remote:FireServer(unpack(data.Args))
                elseif data.Method == "InvokeServer" then data.Remote:InvokeServer(unpack(data.Args)) end
            end)
        end
        fakeLagQueue = {}
    end)
end

--- [Chú thích: Bật Bypass Teleport (Đóng băng xác thật, lướt xác ma)]
function TurnOnBypassTeleport()
    local char = lp.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
