-- 1. NOTIFY SYSTEM (BLACK-BLUE-WHITE)
local function SendNotify(title, text, duration)
    local NotifyGui = coreGui:FindFirstChild("VuKhoa_Notify_System") or Instance.new("ScreenGui", coreGui)
    NotifyGui.Name = "VuKhoa_Notify_System"
    
    local Frame = Instance.new("Frame", NotifyGui)
    Frame.Size = UDim2.new(0, 220, 0, 65)
    Frame.Position = UDim2.new(1, -230, 1, -80)
    Frame.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    Frame.BorderSizePixel = 0
    Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 6)
    local Stroke = Instance.new("UIStroke", Frame)
    Stroke.Color = Color3.fromRGB(0, 120, 255); Stroke.Thickness = 1.8

    local Tl = Instance.new("TextLabel", Frame)
    Tl.Text = "  " .. title; Tl.Size = UDim2.new(1, 0, 0, 25); Tl.BackgroundTransparency = 1
    Tl.TextColor3 = Color3.fromRGB(0, 150, 255); Tl.Font = Enum.Font.Antique; Tl.TextSize = 16; Tl.TextXAlignment = "Left"

    local Tx = Instance.new("TextLabel", Frame)
    Tx.Text = "  " .. text; Tx.Size = UDim2.new(1, 0, 1, -25); Tx.Position = UDim2.new(0, 0, 0, 25); Tx.BackgroundTransparency = 1
    Tx.TextColor3 = Color3.fromRGB(255, 255, 255); Tx.Font = Enum.Font.Antique; Tx.TextSize = 14; Tx.TextXAlignment = "Left"; Tx.TextWrapped = true

    task.delay(duration or 3, function() if Frame then Frame:Destroy() end end)
end

