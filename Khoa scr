local function MakeResizable(frame, minSize, maxSize, onResize)
    local grip = Instance.new("TextButton", frame)
    grip.Name = "ResizeGrip"
    grip.Size = UDim2.new(0, 30, 0, 30)
    grip.Position = UDim2.new(1, -30, 1, -30)
