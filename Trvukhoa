local tC = 0
local gestureStartTime = 0
local isValidTap = false

UserInputService.TouchStarted:Connect(function()
    tC = tC + 1
    if tC == 1 then
        gestureStartTime = tick()
        isValidTap = true
    elseif tC <= 3 then
        if tick() - gestureStartTime > 0.25 then
            isValidTap = false
        end
    end
end)

UserInputService.TouchEnded:Connect(function()
    if tC == 3 and isValidTap then
        if tick() - gestureStartTime <= 0.5 then
            main.Visible = not main.Visible
            isValidTap = false 
        end
    end
    
    tC = math.max(0, tC - 1)
    if tC == 0 then
        isValidTap = false
    end
end)
