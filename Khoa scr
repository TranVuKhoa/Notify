local function MakeCharGhost(targetChar)
    charTransCache = {}
    for _, v in pairs(targetChar:GetDescendants()) do
        if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then
            charTransCache[v] = v.Transparency
            v.Transparency = 1 
        elseif v:IsA("Decal") or v:IsA("Texture") then
            charTransCache[v] = v.Transparency
            v.Transparency = 1
        elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") then
            charTransCache[v] = v.Enabled
            v.Enabled = false
        end
    end
end

local function RestoreCharGhost()
    for obj, val in pairs(charTransCache) do
        if obj and obj.Parent then
            pcall(function() 
                if obj:IsA("BasePart") or obj:IsA("Decal") or obj:IsA("Texture") then
                    obj.Transparency = val 
                else
                    obj.Enabled = val
                end
            end)
        end
    end
    charTransCache = {}
end

local function SetupGhostAnimation(ghost)
    local hum = ghost:FindFirstChild("Humanoid")
    local realAnim = lp.Character:FindFirstChild("Animate")
    ghostAnimTracks = {}
    if hum and realAnim then
        local animator = hum:FindFirstChildOfClass("Animator") or Instance.new("Animator", hum)
        local function loadAnim(nameList)
            for _, name in pairs(nameList) do
                local node = realAnim:FindFirstChild(name)
                if node then
                    local anim = node:FindFirstChildOfClass("Animation")
                    if anim then return animator:LoadAnimation(anim) end
                end
            end
            return nil
        end
        ghostAnimTracks.Walk = loadAnim({"run", "walk"})
        ghostAnimTracks.Idle = loadAnim({"idle"})
        ghostAnimTracks.Jump = loadAnim({"jump"})
        ghostAnimTracks.Fall = loadAnim({"fall"})
        if ghostAnimTracks.Idle then ghostAnimTracks.Idle:Play() end
    end
end

local function StopGhostAnimation()
    for _, track in pairs(ghostAnimTracks) do
        if track and track.IsPlaying then track:Stop() end
    end
    ghostAnimTracks = {}
end

local function FreezeModel(v)
    if v:IsA("Model") and v ~= lp.Character and v.Name ~= "VuKhoa_Ghost_FL" and v.Name ~= "VuKhoa_Ghost" and v.Name ~= "VuKhoa_Bypass_Ghost" then
